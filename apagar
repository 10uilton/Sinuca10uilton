// Resolve "ao vivo" todos os confrontos da rodada que não envolvem o jogador
function resolveOtherMatches(bracket, r) {
  bracket[r].forEach(m => {
    if (m.winner || !m.p1 || !m.p2) return;
    if (m.p1 === 'Você' || m.p2 === 'Você') return; // aguarda o jogador
    m.winner = Math.random() < 0.5 ? m.p1 : m.p2;
  });
}
// Monta a próxima rodada a partir dos vencedores da rodada anterior (já toda decidida)
function buildNextRound(bracket) {
  const prev = bracket[bracket.length - 1];
  const next = [];
  for (let i = 0; i < prev.length; i += 2) {
    next.push({ p1: prev[i].winner, p2: prev[i + 1].winner, winner: null });
  }
  bracket.push(next);
  resolveOtherMatches(bracket, bracket.length - 1);
}
function findPlayerMatch(bracket, r) {
  return bracket[r].find(m => m.p1 === 'Você' || m.p2 === 'Você');
}
function getPlayerOpponent(bracket, r) {
  const m = findPlayerMatch(bracket, r);
  if (!m) return null;
  return m.p1 === 'Você' ? m.p2 : m.p1;
}

function createChampBracket(type) {
  const c = champs.find(x => x.id === type);
  const roundNames = champRoundNames(c.size);
  const usedNames = newAiOpponentSet();
  const participants = ['Você'];
  for (let i = 1; i < c.size; i++) participants.push(randomBrazilianName(usedNames));
  // Embaralha os adversários mantendo "Você" numa posição aleatória da chave
  for (let i = participants.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [participants[i], participants[j]] = [participants[j], participants[i]];
  }
  const round0 = [];
  for (let i = 0; i < participants.length; i += 2) {
    round0.push({ p1: participants[i], p2: participants[i + 1], winner: null });
  }
  const bracket = [round0];
  resolveOtherMatches(bracket, 0);
  champBracket = { type, size: c.size, round: 0, rounds: roundNames.length, roundNames, bracket };
  saveChampBracket();
  return champBracket;
}

function openChampBracket(type) {
