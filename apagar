// ===== AUDIO =====
// Motor de áudio sintetizado (sem samples externos): usamos ruído branco
// filtrado + osciladores com envelopes curtos pra imitar o "crack" seco de
// bolas de bilhar, o thud abafado da tabela e o chacoalhar na caçapa.
let audioCtx = null;
let noiseBuf = null;
let reverbBuf = null;
let distortCurve = null;

function getAudio() {
  if (!audioCtx) { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); loadSamples(); }
  return audioCtx;
}

// ===== SAMPLES REAIS (gravações enviadas) =====
// 3 sons reais embutidos como base64 (sem depender de rede):
//  - hitBall:   bola batendo em bola (jogo normal)
//  - breakHit:  taco/branca batendo no bolo de bolas na saída
//  - whiff:     taca e não acerta nenhuma bola (falta por "ar")
const SAMPLE_DATA = {
  hitBall:  'data:audio/mpeg;base64,',
  breakHit: 'data:audio/mpeg;base64,',
  whiff:    'data:audio/mpeg;base64,'
};
const sampleBuffers = {};
let samplesLoading = false;

function base64ToArrayBuffer(base64) {
  const binary = atob(base64);
  const bytes = new Uint8Array(binary.length);
  for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
  return bytes.buffer;
}

// Decodifica os 3 samples uma única vez, em segundo plano. Enquanto não
// terminar, playSample() devolve false e quem chamou usa o fallback
// sintetizado (assim nunca fica mudo esperando o decode).
function loadSamples() {
  if (samplesLoading) return;
  samplesLoading = true;
  const ctx = getAudio();
  Object.keys(SAMPLE_DATA).forEach(key => {
    const base64 = SAMPLE_DATA[key].split(',')[1];
    let arrBuf;
    try { arrBuf = base64ToArrayBuffer(base64); } catch(e) { return; }
    ctx.decodeAudioData(arrBuf,
      (decoded) => { sampleBuffers[key] = decoded; },
      (err) => { /* fica no fallback sintetizado se falhar */ }
    );
  });
}

// Toca um sample real com leve variação de pitch/volume (evita robotizar
// em repetição). Retorna true se tocou, false se o buffer ainda não
// estava pronto (chamador deve usar o fallback sintetizado nesse caso).
function playSample(key, opts) {
  opts = opts || {};
  const gain = opts.gain === undefined ? 1 : opts.gain;
  const rateJitter = opts.rateJitter === undefined ? 0.03 : opts.rateJitter;
  const ctx = getAudio();
  if (!sampleBuffers[key]) { loadSamples(); return false; }
  try {
    const src = ctx.createBufferSource();
    src.buffer = sampleBuffers[key];
    src.playbackRate.value = 1 + (Math.random()*2-1) * rateJitter;
    const g = ctx.createGain();
    g.gain.value = Math.max(0, Math.min(1.4, gain));
    src.connect(g); g.connect(ctx.destination);
    src.start();
    return true;
  } catch(e) { return false; }
}



// Buffer de ruído branco reaproveitável (1s), usado como matéria-prima
// pra qualquer "clique"/"thud" via filtros diferentes.
function getNoiseBuffer(ctx) {
  if (noiseBuf) return noiseBuf;
  const len = ctx.sampleRate;
  noiseBuf = ctx.createBuffer(1, len, ctx.sampleRate);
  const data = noiseBuf.getChannelData(0);
  for (let i = 0; i < len; i++) data[i] = Math.random() * 2 - 1;
  return noiseBuf;
}

// Impulso curto de "sala pequena" pra dar um pingo de corpo/eco em
// caçapa e vitória, sem soar artificial.
function getReverbBuffer(ctx) {
  if (reverbBuf) return reverbBuf;
  const dur = 0.9, decayPow = 2.4;
  const len = Math.floor(ctx.sampleRate * dur);
  reverbBuf = ctx.createBuffer(2, len, ctx.sampleRate);
  for (let ch = 0; ch < 2; ch++) {
    const data = reverbBuf.getChannelData(ch);
    for (let i = 0; i < len; i++) data[i] = (Math.random()*2-1) * Math.pow(1 - i/len, decayPow);
  }
  return reverbBuf;
}

function getDistortionCurve() {
  if (distortCurve) return distortCurve;
  const n = 8192, k = 16;
  distortCurve = new Float32Array(n);
  for (let i = 0; i < n; i++) {
    const x = (i * 2) / n - 1;
    distortCurve[i] = ((3 + k) * x * 20 * Math.PI/180) / (Math.PI + k * Math.abs(x));
  }
  return distortCurve;
}

// Dispara um burst de ruído filtrado com envelope de ataque/decaimento —
// base pra qualquer transiente de impacto (click, thud, rattle).
function playNoiseBurst(ctx, { start=0, duration=0.12, filterType='bandpass', freq=1500, Q=1, peak=0.3, extraOut }) {
  const now = ctx.currentTime + start;
  const src = ctx.createBufferSource();
  src.buffer = getNoiseBuffer(ctx);
  const filter = ctx.createBiquadFilter();
  filter.type = filterType;
  filter.frequency.value = freq;
  filter.Q.value = Q;
  const g = ctx.createGain();
  g.gain.setValueAtTime(0.0001, now);
  g.gain.linearRampToValueAtTime(peak, now + 0.004);
  g.gain.exponentialRampToValueAtTime(0.0006, now + duration);
  src.connect(filter); filter.connect(g); g.connect(ctx.destination);
  if (extraOut) g.connect(extraOut);
  src.start(now); src.stop(now + duration + 0.02);
  return g;
}

// type: 'hit' | 'pocket' | 'wall' | 'win' | 'foul' | 'achieve'
// intensity: 0-1, opcional — escala o volume/tom pelo "tamanho" do impacto
// (tacada forte, colisão rápida etc.), deixando o som mais dinâmico.
function playSound(type, intensity) {
  intensity = intensity === undefined ? 0.7 : Math.max(0.12, Math.min(1, intensity));
  try {
    const ctx = getAudio();
    const now = ctx.currentTime;

    if (type === 'hit') {
      // Bola batendo em bola / taco batendo na branca: transiente seco
      // (ruído agudo bem curto) + corpo tonal que cai rápido de frequência,
      // simulando o "crack" característico do bilhar.
      const vol = 0.16 + intensity * 0.3;
      playNoiseBurst(ctx, { duration: 0.045 + intensity*0.02, filterType:'bandpass', freq: 2500 + intensity*900, Q: 2.4, peak: vol*0.85 });
      const o = ctx.createOscillator();
      const g = ctx.createGain();
      o.type = 'sine';
      o.frequency.setValueAtTime(1300 + intensity*500, now);
      o.frequency.exponentialRampToValueAtTime(280, now + 0.09);
      g.gain.setValueAtTime(vol*0.65, now);
      g.gain.exponentialRampToValueAtTime(0.0007, now + 0.1);
      o.connect(g); g.connect(ctx.destination);
      o.start(now); o.stop(now + 0.11);

    } else if (type === 'wall') {
      // Tacada na almofada de borracha: thud grave e abafado, sem o brilho
      // metálico que tinha a onda quadrada antiga.
      const vol = 0.14 + intensity * 0.18;
      playNoiseBurst(ctx, { duration: 0.09, filterType:'lowpass', freq: 480, Q: 0.7, peak: vol });
      const o = ctx.createOscillator();
      const g = ctx.createGain();
      o.type = 'sine';
      o.frequency.setValueAtTime(135, now);
      o.frequency.exponentialRampToValueAtTime(65, now + 0.08);
      g.gain.setValueAtTime(vol*0.75, now);
      g.gain.exponentialRampToValueAtTime(0.0007, now + 0.09);
      o.connect(g); g.connect(ctx.destination);
      o.start(now); o.stop(now + 0.1);

    } else if (type === 'pocket') {
      // Bola caindo na caçapa: thonk grave + 2-3 batidinhas de ruído
      // (chacoalhar no fundo de couro/madeira), com um toque de reverb
      // curto pra dar sensação de "bolso" fechado.
      const convolver = ctx.createConvolver();
      convolver.buffer = getReverbBuffer(ctx);
      const wet = ctx.createGain();
      wet.gain.value = 0.3;
      convolver.connect(wet); wet.connect(ctx.destination);

      const o = ctx.createOscillator();
      const g = ctx.createGain();
      o.type = 'sine';
      o.frequency.setValueAtTime(200, now);
      o.frequency.exponentialRampToValueAtTime(80, now + 0.18);
      g.gain.setValueAtTime(0.32, now);
      g.gain.exponentialRampToValueAtTime(0.0007, now + 0.22);
      o.connect(g); g.connect(ctx.destination); g.connect(convolver);
      o.start(now); o.stop(now + 0.22);

      [0, 0.07, 0.15].forEach((dt, i) => {
        playNoiseBurst(ctx, { start: dt, duration: 0.06, filterType:'bandpass', freq: 900 - i*180, Q: 1.5, peak: 0.2 * Math.pow(0.6, i), extraOut: convolver });
      });

    } else if (type === 'win') {
      const notes = [523,659,784,1047];
      const convolver = ctx.createConvolver();
      convolver.buffer = getReverbBuffer(ctx);
      const wet = ctx.createGain(); wet.gain.value = 0.22;
      convolver.connect(wet); wet.connect(ctx.destination);
      notes.forEach((f, i) => {
        const o2 = ctx.createOscillator();
        const g2 = ctx.createGain();
        o2.connect(g2); g2.connect(ctx.destination); g2.connect(convolver);
        const t = now + i * 0.12;
        o2.type = 'triangle';
        o2.frequency.setValueAtTime(f, t);
        g2.gain.setValueAtTime(0.2, t);
        g2.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
        o2.start(t); o2.stop(t + 0.25);
      });
    } else if (type === 'foul') {
      // Buzzer mais "elétrico": dente-de-serra grave com leve distorção
      // (waveshaper), em vez do tom limpo de antes.
      const o = ctx.createOscillator();
      const g = ctx.createGain();
      const shaper = ctx.createWaveShaper();
      shaper.curve = getDistortionCurve();
      o.type = 'sawtooth';
      o.frequency.setValueAtTime(90, now);
      o.frequency.linearRampToValueAtTime(68, now + 0.28);
      g.gain.setValueAtTime(0.26, now);
      g.gain.exponentialRampToValueAtTime(0.001, now + 0.32);
      o.connect(shaper); shaper.connect(g); g.connect(ctx.destination);
      o.start(now); o.stop(now + 0.32);
    } else if (type === 'achieve') {
      const notes = [659, 988];
      notes.forEach((f, i) => {
        const o2 = ctx.createOscillator();
        const g2 = ctx.createGain();
        o2.connect(g2); g2.connect(ctx.destination);
        const t = now + i * 0.09;
        o2.type = 'triangle';
        o2.frequency.setValueAtTime(f, t);
        g2.gain.setValueAtTime(0.22, t);
        g2.gain.exponentialRampToValueAtTime(0.001, t + 0.3);
        o2.start(t); o2.stop(t + 0.3);
      });
    }
  } catch(e){}
}

