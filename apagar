function checkAchievements(context = {}) {
  const a = state.achievements;
  const add = (id) => {
    if (!a.includes(id)) {
      a.push(id);
      const t = trophies.find(tr => tr.id === id);
      if (t) showAchievementToast(t.icon, t.name);
    }
  };

  // Entrada — concedida na primeira vez que entra (chamada no init)
  add('welcome');

  // Vitórias progressivas
  if (state.wins >= 1)    add('first_win');
  if (state.wins >= 10)   add('ten_wins');
  if (state.wins >= 50)   add('wins_50');
  if (state.wins >= 100)  add('wins_100');
  if (state.wins >= 200)  add('wins_200');
  if (state.wins >= 300)  add('wins_300');
  if (state.wins >= 400)  add('wins_400');
  if (state.wins >= 500)  add('wins_500');
  if (state.wins >= 600)  add('wins_600');
  if (state.wins >= 700)  add('wins_700');
  if (state.wins >= 800)  add('wins_800');
  if (state.wins >= 900)  add('wins_900');
  if (state.wins >= 1000) add('wins_1000');
  if (state.wins > 1000)  add('legend');

  // Financeiro
  if (state.coins >= 100000) add('rich');

  // Loja — injetado via contexto
  if (context.bought) add('shopper');

  // Campeonatos
  if (state.champLevel >= 1) add('champ_unlocked');
  if (context.champWon === 'regional') add('champ_regional');
  if (context.champWon === 'estadual') add('champ_estadual');
  if (context.champWon === 'nacional') add('champ_nacional');
  if (context.champWon === 'master')   add('champion');

  // Modo carreira — início
  if (state.careerCity >= 1) add('traveler');

  // Taças por cidade vencida (context.cityIdx = índice da cidade que acabou de vencer)
  const tacaMap = ['taca_portovelho','taca_riobranco','taca_manaus','taca_boavista','taca_macapa','taca_belem','taca_palmas','taca_saoluis','taca_teresina','taca_fortaleza','taca_natal','taca_joaopessoa','taca_olinda','taca_recife','taca_maceio','taca_aracaju','taca_barreiras','taca_conquista','taca_feira','taca_salvador','taca_goiania','taca_bsb','taca_cuiaba','taca_campogrande','taca_uberlandia','taca_uberaba','taca_bh','taca_vitoria','taca_rio','taca_braganca','taca_campinas','taca_santos','taca_sp','taca_cwb','taca_floripa','taca_poa'];
  if (context.cityIdx !== undefined) add(tacaMap[context.cityIdx]);

  // Carreira completa (Porto Alegre = índice 35, cities.length-1)
  if (state.careerCity >= 36) add('career_complete');

  // Dificuldade IA
  if (context.difficulty === 'easy')   add('win_easy');
  if (context.difficulty === 'medium') add('win_medium');
  if (context.difficulty === 'hard')   add('win_hard');

  // Modo Ficha — série vencida
  if (context.fichaWon) {
    const bet = context.fichaBet;
    if (bet === 1) add('ficha_win_1');
    if (bet === 3) add('ficha_win_3');
    if (bet === 5) add('ficha_win_5');
    // Rei do Bar: venceu com 1, 3 e 5
    if (a.includes('ficha_win_1') && a.includes('ficha_win_3') && a.includes('ficha_win_5')) {
      add('ficha_king');
    }
  }

  saveState();
}
