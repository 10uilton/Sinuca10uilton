function getBallColor(n) {
  const colors = {
    0: '#f5f5f5',  // white (cue)
    1: '#f5c518',  // yellow
    2: '#1565c0',  // blue
    3: '#d32f2f',  // red
    4: '#7b1fa2',  // purple
    5: '#e65100',  // orange
    6: '#1b5e20',  // green
    7: '#880e4f',  // maroon
    8: '#4a148c',  // roxo escuro (distinto da 4 que é roxo médio)
    9: '#f57f17',  // âmbar dourado (solid)
    10: '#212121', // preta (bola especial - última)
    11: '#f5c518', // striped yellow
    12: '#1565c0',
    13: '#d32f2f',
    14: '#7b1fa2',
    15: '#e65100',
    16: '#1b5e20',
