let toastTimer;
let toastEndTime = 0; // timestamp em ms quando o toast atual vai sumir

// Agenda a IA para jogar após todas as mensagens na tela desaparecerem
function scheduleAIAfterMessages(extraDelay) {
  extraDelay = extraDelay || 0;
  const now = Date.now();
  const waitFor = Math.max(0, toastEndTime - now) + extraDelay;
  clearTimeout(aiThinkTimer);
  aiThinkTimer = setTimeout(() => aiShoot(), waitFor);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  const emojiEl = document.getElementById('toastEmoji');
  const textEl = document.getElementById('toastText');

  // Detect type by leading emoji/keyword
  let type = 'info';
  if (msg.startsWith('💀')) type = 'death';
  else if (msg.startsWith('⚠️')) type = 'foul';
  else if (msg.startsWith('✅')) type = 'success';
  else if (msg.startsWith('🎯')) type = 'announce';

  // Split leading emoji from rest of text
  const emojiMatch = msg.match(/^(\p{Emoji_Presentation}|\p{Extended_Pictographic})\s*/u);
  let emoji = '', text = msg;
  if (emojiMatch) {
    emoji = emojiMatch[0].trim();
    text = msg.slice(emojiMatch[0].length);
  }

  if (emoji === '🎱') {
    emojiEl.innerHTML = '<img src="data:image/svg+xml;base64," alt="Bola 10" style="width:1em;height:1em;vertical-align:-0.15em;border-radius:50%;display:inline-block;">';
  } else {
    emojiEl.textContent = emoji;
  }
  textEl.textContent = text;

  t.className = `toast type-${type}`;
  // Force reflow to restart animation
  void t.offsetWidth;
  t.classList.add('show');

  clearTimeout(toastTimer);
  const duration = type === 'death' ? 2800 : type === 'foul' ? 2200 : 1800;
  toastEndTime = Date.now() + duration;
  toastTimer = setTimeout(() => t.classList.remove('show'), duration);
}

