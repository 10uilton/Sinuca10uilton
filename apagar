<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Sinuca 10uilton</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&family=Orbitron:wght@700;900&display=swap');

  :root {
    --verde: #1a6b2e;
    --verde-claro: #2d9e47;
    --dourado: #f0c040;
    --dourado2: #e8a800;
    --preto: #0a0a0a;
    --cinza: #1c1c1c;
    --cinza2: #2a2a2a;
    --branco: #f5f5f5;
    --vermelho: #d32f2f;
    --azul: #1565c0;
  }

  * { margin:0; padding:0; box-sizing:border-box; touch-action:manipulation; }

  html {
    background:#000;
    height:100%;
  }

  body {
    background:#0a0a0a;
    font-family:'Rajdhani',sans-serif;
    color:#fff;
    overflow:hidden;
    height:100dvh;
    width:100%;
    max-width:480px;
    margin:0 auto;
    position:relative;
    box-shadow:0 0 40px rgba(0,0,0,0.6);
    user-select:none;
  }

  /* ===== SCREENS ===== */
  .screen { display:none; width:100%; height:100dvh; position:absolute; top:0; left:0; overflow:hidden; }
  .screen.active { display:flex; flex-direction:column; }

  /* Telas com rolagem */
  .screen.scrollable { overflow-y:auto; -webkit-overflow-scrolling:touch; }
  .screen.scrollable .scroll-inner { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; }

  /* ===== MENU ===== */
  #menuScreen {
    background: radial-gradient(ellipse at 50% 0%, #1a5c2a 0%, #0a0a0a 70%);
    align-items:center;
    justify-content:space-between;
    flex-direction:column;
    overflow:hidden;
  }

  /* ===== BOTÃO INFO (menu) ===== */
  #menuInfoBtn {
    position:absolute;
    top:12px; left:12px;
    background:rgba(10,10,10,0.75);
    border:1px solid rgba(255,255,255,0.14);
    border-radius:10px;
    width:40px; height:40px;
    color:#aaa;
    font-size:18px; font-weight:700;
    cursor:pointer;
    z-index:10;
    display:flex; align-items:center; justify-content:center;
    backdrop-filter:blur(6px);
    transition:all 0.2s;
    -webkit-tap-highlight-color:transparent;
  }
  #menuInfoBtn:active { background:rgba(240,192,64,0.15); border-color:rgba(240,192,64,0.4); color:#f0c040; }

  /* ===== TELA INFO ===== */
  #infoScreen {
    background: radial-gradient(ellipse at 50% 10%, #0e2a1a 0%, #0a0a0a 75%);
    align-items:stretch; justify-content:flex-start;
  }
  #infoScreen .info-scroll {
    flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch;
    display:flex; flex-direction:column; align-items:center;
  }
  .info-header {
    padding:14px 60px 14px 16px;
    background:rgba(0,0,0,0.6);
    border-bottom:1px solid rgba(255,255,255,0.08);
    flex-shrink:0;
  }
  .info-title {
    font-family:'Orbitron',monospace;
    font-size:18px; color:var(--dourado);
    text-shadow:0 0 24px rgba(240,192,64,0.45);
    letter-spacing:3px;
  }
  .info-subtitle {
    font-size:11px; color:#666; letter-spacing:4px; text-transform:uppercase;
    margin-top:3px;
  }
  .info-inner {
    width:100%; max-width:480px;
    padding:20px 20px max(24px, env(safe-area-inset-bottom));
    display:flex; flex-direction:column; gap:18px;
  }
  .info-card {
    background:rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.09);
    border-radius:16px;
    padding:16px 18px;
  }
  .info-card-title {
    font-family:'Rajdhani',sans-serif;
    font-size:13px; font-weight:700;
    color:var(--dourado); letter-spacing:2px; text-transform:uppercase;
    margin-bottom:10px;
    display:flex; align-items:center; gap:8px;
  }
  .info-card p {
    font-size:13.5px; color:#bbb; line-height:1.65;
    margin:0;
  }
  .info-card p + p { margin-top:8px; }
  .info-mode-list {
    display:flex; flex-direction:column; gap:8px;
    margin-top:2px;
  }
  .info-mode-item {
    display:flex; align-items:flex-start; gap:10px;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.07);
    border-radius:10px;
    padding:10px 12px;
  }
  .info-mode-icon { font-size:20px; flex-shrink:0; margin-top:1px; }
  .info-mode-name { font-size:13px; font-weight:700; color:#fff; }
  .info-mode-desc { font-size:11.5px; color:#888; margin-top:2px; line-height:1.4; }
  .info-gift-row {
    display:flex; align-items:center; gap:12px;
    background:rgba(240,192,64,0.07);
    border:1px solid rgba(240,192,64,0.2);
    border-radius:12px; padding:12px 16px;
  }
  .info-gift-icon { font-size:28px; }
  .info-gift-text { font-size:13px; color:#ddd; line-height:1.5; }
  .info-gift-text strong { color:var(--dourado); }

  .html-badge {
    position:absolute;
    top:12px; right:12px;
    background:#e53935;
    color:#fff;
    font-family:'Orbitron',monospace;
    font-size:11px;
    font-weight:900;
    letter-spacing:2px;
    padding:4px 10px;
    border-radius:5px;
    z-index:10;
    box-shadow:0 2px 8px rgba(229,57,53,0.5);
    pointer-events:none;
    user-select:none;
  }

  /* ===== PERFIL DO JOGADOR (menu) ===== */
  .profile-widget {
    display:flex; flex-direction:column; align-items:center;
    gap:4px; margin-bottom:2px;
    cursor:pointer; -webkit-tap-highlight-color:transparent;
  }
  .profile-avatar-wrap {
    width:72px; height:72px; border-radius:50%;
    position:relative;
    animation: ballFloat 3s ease-in-out infinite;
  }
  .profile-avatar {
    width:100%; height:100%; border-radius:50%;
    object-fit:cover;
    border:2.5px solid var(--dourado);
    box-shadow:0 0 14px rgba(240,192,64,0.4);
    display:block;
  }
  .profile-avatar-empty {
    width:100%; height:100%; border-radius:50%;
    border:2.5px dashed rgba(240,192,64,0.6);
    background:rgba(255,255,255,0.04);
    display:flex; align-items:center; justify-content:center;
    font-size:28px; color:var(--dourado);
    box-shadow:0 0 14px rgba(240,192,64,0.2);
  }
  .profile-widget-name {
    font-family:'Orbitron',monospace; font-size:14px; color:var(--dourado);
    letter-spacing:1px; margin-top:2px;
  }
  .profile-widget-age {
    font-size:11px; color:#999; letter-spacing:1px;
  }
  .profile-widget-cta {
    font-family:'Rajdhani',sans-serif; font-size:12px; color:var(--dourado);
    letter-spacing:1px; margin-top:2px; text-decoration:underline;
  }

  /* ===== TELA DE PERFIL ===== */
  #profileScreen { background:radial-gradient(ellipse at 50% 0%, #1a1a2a 0%, #0a0a0a 80%); }
  .profile-header { padding:16px; background:rgba(0,0,0,0.6); border-bottom:1px solid rgba(255,255,255,0.08); flex-shrink:0; }
  .profile-header .info-title { font-family:'Orbitron',monospace; font-size:18px; color:var(--dourado); }
  .profile-header .info-subtitle { font-size:11px; color:#888; }
  .profile-scroll { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; }
  .profile-form { padding:20px; max-width:420px; margin:0 auto; }
  .profile-photo-picker { display:flex; flex-direction:column; align-items:center; margin-bottom:20px; }
  .profile-photo-circle {
    width:96px; height:96px; border-radius:50%;
    border:2.5px dashed rgba(240,192,64,0.6);
    background:rgba(255,255,255,0.04);
    display:flex; align-items:center; justify-content:center;
    font-size:32px; color:var(--dourado);
    overflow:hidden; cursor:pointer; position:relative;
  }
  .profile-photo-circle img { width:100%; height:100%; object-fit:cover; }
  .profile-photo-hint { font-size:11px; color:#888; margin-top:8px; }
  .form-group { margin-bottom:16px; }
  .form-label { font-size:12px; color:var(--dourado); letter-spacing:1px; text-transform:uppercase; margin-bottom:6px; display:block; }
  .form-input, .form-select {
    width:100%; padding:12px 14px; border-radius:10px;
    background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15);
    color:#fff; font-family:'Rajdhani',sans-serif; font-size:15px;
    -webkit-tap-highlight-color:transparent;
  }
  .form-input:focus, .form-select:focus { outline:none; border-color:var(--dourado); }
  .form-row { display:flex; gap:10px; }
  .form-row .form-group { flex:1; }
  .profile-age-display {
    text-align:center; font-family:'Orbitron',monospace; color:var(--dourado);
    font-size:13px; margin:-4px 0 16px;
  }
  .profile-save-btn {
    width:100%; padding:14px; border-radius:12px; border:none;
    background:linear-gradient(135deg,var(--dourado),var(--dourado2));
    color:#111; font-weight:700; font-size:15px; letter-spacing:1px;
    cursor:pointer; -webkit-tap-highlight-color:transparent;
  }
  .profile-save-btn:active { transform:scale(0.98); }
  .profile-birthday-note {
    display:flex; align-items:center; gap:10px; margin-top:16px;
    padding:12px 14px; border-radius:12px;
    background:rgba(240,192,64,0.08); border:1px solid rgba(240,192,64,0.3);
    font-size:12px; color:#ccc;
  }


  /* ===== ANIMAÇÃO DE FLUTUAR (reaproveitada no avatar do perfil) ===== */
  @keyframes ballFloat {
    0%,100% { transform: translateY(0px); }
    50%      { transform: translateY(-6px); }
  }

  .menu-scroll-area {
    flex:1;
    overflow-y:auto;
    -webkit-overflow-scrolling:touch;
    width:100%;
    display:flex;
    flex-direction:column;
    align-items:center;
  }

  .menu-social-bar {
    flex-shrink:0;
    width:100%;
    display:flex;
    justify-content:center;
    padding:10px 0 max(14px, env(safe-area-inset-bottom));
    background:linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
    position:relative;
    z-index:2;
  }

  .menu-bg {
    position:absolute; inset:0; overflow:hidden; pointer-events:none;
  }
  .menu-bg::before {
    content:'';
    position:absolute; top:-50%; left:-50%;
    width:200%; height:200%;
    background: repeating-linear-gradient(
      45deg,
      transparent 0, transparent 40px,
      rgba(240,192,64,0.03) 40px, rgba(240,192,64,0.03) 41px
    );
    animation: bgMove 20s linear infinite;
  }
  @keyframes bgMove { to { transform: translate(41px,41px); } }

  .menu-logo {
    text-align:center;
    padding:12px 20px 4px;
    position:relative;
    z-index:2;
  }
  .logo-cue {
    font-size:40px;
    line-height:1;
    display:block;
  }
  .logo-title {
    font-family:'Orbitron',monospace;
    font-size:clamp(24px,7vw,46px);
    font-weight:900;
    color: var(--dourado);
    text-shadow: 0 0 30px rgba(240,192,64,0.6), 0 2px 0 #8a6800;
    letter-spacing:4px;
    line-height:1;
  }
  .logo-sub {
    font-family:'Rajdhani',sans-serif;
    font-size:11px;
    letter-spacing:6px;
    color:#aaa;
    margin-top:2px;
  }
  .logo-balls {
    display:flex;
    justify-content:center;
    gap:5px;
    margin-top:8px;
  }
  .mini-ball {
    width:16px; height:16px;
    border-radius:50%;
    border:1.5px solid rgba(255,255,255,0.3);
    box-shadow:0 2px 6px rgba(0,0,0,0.5);
  }

  .menu-coins {
    display:flex; align-items:center; gap:10px;
    margin:6px 0 10px;
    position:relative; z-index:2;
  }
  .menu-coin-badge {
    display:flex; align-items:center; gap:6px;
    border-radius:20px;
    padding:6px 14px;
    font-family:'Orbitron',monospace;
    font-size:14px;
  }
  .menu-coin-badge.money {
    background:rgba(240,192,64,0.15);
    border:1px solid rgba(240,192,64,0.4);
    color: var(--dourado);
  }
  .menu-coin-badge.chips {
    background:rgba(100,200,255,0.12);
    border:1px solid rgba(100,200,255,0.35);
    color: #7dd8ff;
  }

  .menu-nav {
    display:flex;
    flex-direction:column;
    gap:7px;
    width:100%;
    max-width:340px;
    padding:0 20px 10px;
    position:relative; z-index:2;
  }

  .menu-btn {
    display:flex; align-items:center; gap:14px;
    background:linear-gradient(135deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.02) 100%);
    border:1px solid rgba(255,255,255,0.12);
    border-radius:14px;
    padding:11px 18px;
    cursor:pointer;
    transition:all 0.2s;
    position:relative;
    overflow:hidden;
    -webkit-tap-highlight-color:transparent;
  }
  .menu-btn::before {
    content:'';
    position:absolute; left:-100%; top:0;
    width:100%; height:100%;
    background:linear-gradient(90deg,transparent,rgba(255,255,255,0.08),transparent);
    transition:left 0.4s;
  }
  .menu-btn:active::before { left:100%; }
  .menu-btn:active { transform:scale(0.97); border-color:var(--dourado); }
  .menu-btn.primary {
    background:linear-gradient(135deg, #1a6b2e 0%, #0e4a1e 100%);
    border-color:rgba(240,192,64,0.5);
    box-shadow:0 4px 20px rgba(26,107,46,0.4);
  }
  .btn-icon { font-size:26px; min-width:32px; text-align:center; }
  .btn-info { flex:1; }
  .btn-title { font-family:'Rajdhani',sans-serif; font-size:17px; font-weight:700; color:#fff; line-height:1.1; }
  .btn-desc { font-size:11px; color:#888; margin-top:1px; }
  .btn-arrow { color:#555; font-size:16px; }

  .menu-social {
    display:flex; gap:10px;
    position:relative; z-index:2;
  }
  .social-btn {
    display:flex; align-items:center; justify-content:center;
    background:rgba(255,255,255,0.07);
    border:1px solid rgba(255,255,255,0.1);
    border-radius:50%;
    width:36px; height:36px;
    color:#aaa;
    cursor:pointer; text-decoration:none;
    transition:all 0.2s;
    -webkit-tap-highlight-color:transparent;
  }
  .social-btn:active { background:rgba(255,255,255,0.15); color:#fff; }
  .social-icon { width:16px; height:16px; flex-shrink:0; display:block; }
  .social-btn.ig:active { border-color:#e1306c; }
  .social-btn.xtw:active { border-color:#fff; }
  .social-btn.blog:active { border-color:#f26522; }
  .social-btn.fb:active { border-color:#1877f2; }


  /* ===== BOTÃO FIXO FECHAR (✕) ===== */
  #globalCloseBtn {
    display:none;
    position:fixed; top:12px; right:12px;
    z-index:999;
    background:rgba(10,10,10,0.85);
    border:1px solid rgba(255,255,255,0.12);
    border-radius:10px;
    width:40px; height:40px;
    color:#aaa;
    font-size:16px; font-weight:700;
    cursor:pointer;
    -webkit-tap-highlight-color:transparent;
    backdrop-filter:blur(6px);
    transition:all 0.2s;
    align-items:center; justify-content:center;
  }
  #globalCloseBtn.visible { display:flex; }
  #globalCloseBtn:active { background:rgba(240,192,64,0.15); border-color:rgba(240,192,64,0.4); color:#f0c040; }

  /* ===== SUBMENU ===== */
  #submodeScreen {
    background: radial-gradient(ellipse at 50% 30%, #0a2a3a 0%, #0a0a0a 70%);
    align-items:center; justify-content:center;
  }
  .submode-box {
    width:100%; max-width:340px;
    padding:20px;
    display:flex; flex-direction:column; gap:14px;
  }
  .submode-title {
    font-family:'Orbitron',monospace;
    font-size:20px; color:var(--dourado);
    text-align:center; margin-bottom:10px;
  }
  .submode-btn {
    display:flex; align-items:center; gap:14px;
    background:rgba(255,255,255,0.06);
    border:1px solid rgba(255,255,255,0.12);
    border-radius:14px; padding:16px 18px;
    cursor:pointer; transition:all 0.2s;
    -webkit-tap-highlight-color:transparent;
  }
  .submode-btn:active { transform:scale(0.97); border-color:var(--dourado); background:rgba(240,192,64,0.1); }
  .back-btn {
    background:rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.08);
    border-radius:10px; padding:12px;
    text-align:center; cursor:pointer; color:#888;
    font-size:14px; transition:all 0.2s;
    -webkit-tap-highlight-color:transparent;
  }
  .back-btn:active { color:#fff; }

  /* ===== DIFFICULTY SELECT ===== */
  #difficultyScreen {
    background: radial-gradient(ellipse at 50% 30%, #0a2a3a 0%, #0a0a0a 70%);
    align-items:center; justify-content:center;
  }
  .diff-box {
    width:100%; max-width:340px;
    padding:20px;
    display:flex; flex-direction:column; gap:12px;
  }
  .diff-title {
    font-family:'Orbitron',monospace;
    font-size:18px; color:var(--dourado);
    text-align:center; margin-bottom:6px;
  }
  .diff-subtitle {
    font-size:12px; color:#666;
    text-align:center; margin-bottom:4px;
    letter-spacing:0.5px;
  }
  .diff-btn {
    display:flex; align-items:center; gap:12px;
    border-radius:14px; padding:14px 16px;
    cursor:pointer; transition:all 0.2s;
    -webkit-tap-highlight-color:transparent;
    border:2px solid transparent;
    overflow:hidden;
  }
  .diff-btn:active { transform:scale(0.97); }
  .diff-btn.easy {
    background:linear-gradient(135deg, rgba(76,175,80,0.15) 0%, rgba(76,175,80,0.05) 100%);
    border-color:rgba(76,175,80,0.45);
  }
  .diff-btn.easy:active { background:rgba(76,175,80,0.25); }
  .diff-btn.medium {
    background:linear-gradient(135deg, rgba(255,152,0,0.15) 0%, rgba(255,152,0,0.05) 100%);
    border-color:rgba(255,152,0,0.45);
  }
  .diff-btn.medium:active { background:rgba(255,152,0,0.25); }
  .diff-btn.hard {
    background:linear-gradient(135deg, rgba(211,47,47,0.18) 0%, rgba(211,47,47,0.06) 100%);
    border-color:rgba(211,47,47,0.5);
  }
  .diff-btn.hard:active { background:rgba(211,47,47,0.28); }
  .diff-icon { font-size:28px; min-width:38px; text-align:center; flex-shrink:0; }
  .diff-info { flex:1; min-width:0; }
  .diff-name { font-size:16px; font-weight:800; line-height:1.1; }
  .diff-name.easy { color:#66bb6a; }
  .diff-name.medium { color:#ffa726; }
  .diff-name.hard { color:#ef5350; }
  .diff-desc { font-size:11px; color:#aaa; margin-top:3px; line-height:1.3; }
  .diff-stars { font-size:13px; margin-top:4px; }
  .diff-badge {
    flex-shrink:0; align-self:center;
    font-size:10px; font-weight:700; letter-spacing:0.5px;
    padding:3px 8px; border-radius:20px;
    white-space:nowrap;
  }
  .diff-badge.easy { background:rgba(76,175,80,0.2); color:#66bb6a; border:1px solid rgba(76,175,80,0.3); }
  .diff-badge.medium { background:rgba(255,152,0,0.2); color:#ffa726; border:1px solid rgba(255,152,0,0.3); }
  .diff-badge.hard { background:rgba(211,47,47,0.2); color:#ef5350; border:1px solid rgba(211,47,47,0.3); }

  /* ===== GAME SCREEN ===== */
  #gameScreen {
    background:#111;
    flex-direction:column;
    overflow:hidden;
  }

  .game-hud {
    display:flex; align-items:stretch; justify-content:space-between;
    background:rgba(0,0,0,0.92);
    border-bottom:1px solid rgba(255,255,255,0.08);
    flex-shrink:0;
    min-height:56px;
    gap:4px;
    padding:0 4px;
  }
  .hud-player {
    display:flex; align-items:center; gap:8px;
    font-size:13px; font-weight:700;
    flex:1;
    padding:6px 10px;
    border-radius:10px;
    margin:5px 2px;
    background:rgba(255,255,255,0.04);
    border:1.5px solid rgba(255,255,255,0.07);
    color:#888;
    transition: all 0.25s ease;
    position:relative;
    overflow:hidden;
  }
  .hud-player::before {
    content:'';
    position:absolute; inset:0;
    opacity:0;
    transition: opacity 0.25s ease;
  }
  .hud-player.active {
    color:#fff;
    background:rgba(240,192,64,0.13);
    border-color:rgba(240,192,64,0.55);
    box-shadow: 0 0 14px rgba(240,192,64,0.22), inset 0 0 16px rgba(240,192,64,0.06);
  }
  .hud-player.active::before {
    background: linear-gradient(135deg, rgba(240,192,64,0.10) 0%, transparent 60%);
    opacity:1;
  }
  .hud-player .player-dot {
    width:12px; height:12px; border-radius:50%;
    background:#333;
    border:2px solid #555;
    flex-shrink:0;
    transition: all 0.25s ease;
  }
  .hud-player.active .player-dot {
