function updateAim(mx, my) {
  if (!cueBall) return;
  cueAngle = Math.atan2(my - cueBall.y, mx - cueBall.x) + Math.PI; // invertido: toca atrás do taco, bola vai pra frente
  const deg = Math.round(cueAngle * 180 / Math.PI);
  document.getElementById('angleInfo').textContent = deg + '°';
}

