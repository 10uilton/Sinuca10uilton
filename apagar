  /* Toast */
  /* ===== TOAST CENTRAL ===== */
  .toast {
    position:fixed;
    top:50%; left:50%;
    transform:translate(-50%, -50%) scale(0.7);
    z-index:300;
    pointer-events:none;
    opacity:0;
    transition: opacity 0.18s ease, transform 0.22s cubic-bezier(.21,1.02,.73,1);
    text-align:center;
    max-width: min(88vw, 360px);
  }
  .toast.show {
    opacity:1;
    transform:translate(-50%, -50%) scale(1);
  }
  .toast-inner {
    display:inline-flex;
    flex-direction:column;
    align-items:center;
    gap:6px;
    padding:18px 28px 16px;
    border-radius:20px;
    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);
    box-shadow:0 8px 40px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06) inset;
  }
  .toast-emoji {
    font-size:36px;
    line-height:1;
    filter:drop-shadow(0 2px 6px rgba(0,0,0,0.5));
  }
  .toast-text {
    font-family:'Rajdhani',sans-serif;
    font-size:17px;
    font-weight:700;
    letter-spacing:0.3px;
    line-height:1.3;
    color:#fff;
    text-shadow:0 1px 4px rgba(0,0,0,0.6);
  }
  /* Variantes por tipo */
  .toast.type-foul .toast-inner {
    background: rgba(180,30,30,0.92);
    border:1.5px solid rgba(255,80,80,0.55);
  }
  .toast.type-death .toast-inner {
    background: rgba(60,0,0,0.96);
    border:2px solid rgba(220,30,30,0.8);
    box-shadow:0 8px 40px rgba(180,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.05) inset;
  }
  .toast.type-success .toast-inner {
    background: rgba(20,100,40,0.92);
    border:1.5px solid rgba(80,200,100,0.5);
  }
  .toast.type-info .toast-inner {
    background: rgba(20,20,30,0.92);
    border:1.5px solid rgba(240,192,64,0.45);
  }
  .toast.type-announce .toast-inner {
    background: rgba(15,40,80,0.94);
    border:1.5px solid rgba(100,160,255,0.5);
  }

