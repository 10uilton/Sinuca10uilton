let angleSpinInterval = null;
function startAngleSpin(dir, e) {
  if (e) e.preventDefault();
  stopAngleSpin();
  rotateCue(dir);
  angleSpinInterval = setInterval(() => rotateCue(dir), 80);
}
function stopAngleSpin() {
  if (angleSpinInterval) { clearInterval(angleSpinInterval); angleSpinInterval = null; }
}
function rotateCue(dir) {
  if (ballsMoving || !cueBall || !cueBall.active) return;
  cueAngle += dir * 0.05;
  const deg = Math.round(cueAngle * 180 / Math.PI);
  const el = document.getElementById('angleInfo');
  if (el) el.textContent = deg + '°';
}
document.addEventListener('mouseup', stopAngleSpin);
document.addEventListener('touchend', stopAngleSpin);

// ===== CONTROLS =====
// Aim: touch/mouse on canvas
let touching = false, touchStartX, touchStartY;
let canvasListenersAdded = false;

function addCanvasListeners() {
  if (canvasListenersAdded) return;
  canvasListenersAdded = true;

  canvas.addEventListener('touchstart', e => {
    e.preventDefault();
    if (ballInHandMode) return;
    if (ballsMoving || !cueBall.active || playerType[currentPlayer]!=='human') return;
    touching = true;
    const t = e.touches[0];
    const r = canvas.getBoundingClientRect();
    touchStartX = t.clientX - r.left;
    touchStartY = t.clientY - r.top;
    updateAim(touchStartX, touchStartY);
  }, { passive:false });

  canvas.addEventListener('touchmove', e => {
    e.preventDefault();
    if (ballInHandMode) return;
    if (!touching) return;
    const t = e.touches[0];
    const r = canvas.getBoundingClientRect();
    updateAim(t.clientX - r.left, t.clientY - r.top);
  }, { passive:false });

  canvas.addEventListener('touchend', e => {
    if (ballInHandMode) return;
    touching = false;
  });

  canvas.addEventListener('mousemove', e => {
    if (ballInHandMode) return;
    if (ballsMoving || !cueBall.active || playerType[currentPlayer]!=='human') return;
    const r = canvas.getBoundingClientRect();
    updateAim(e.clientX - r.left, e.clientY - r.top);
  });
}

