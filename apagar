function calcAge(birthdateStr) {
  if (!birthdateStr) return null;
  const b = new Date(birthdateStr + 'T00:00:00');
  if (isNaN(b.getTime())) return null;
  const now = new Date();
  let age = now.getFullYear() - b.getFullYear();
  const hadBirthdayThisYear = (now.getMonth() > b.getMonth()) ||
    (now.getMonth() === b.getMonth() && now.getDate() >= b.getDate());
  if (!hadBirthdayThisYear) age--;
  return age;
}
function openProfileScreen() {
  document.getElementById('profileFirstName').value = state.profileFirstName;
  document.getElementById('profileLastName').value = state.profileLastName;
  document.getElementById('profileGender').value = state.profileGender;
  document.getElementById('profileBirthdate').value = state.profileBirthdate;
  const circle = document.getElementById('profilePhotoCircle');
  circle.innerHTML = state.profilePhoto ? `<img src="${state.profilePhoto}" alt="Foto do perfil">` : '📷';
  updateProfileAgePreview();
  showScreen('profileScreen');
}
function onProfilePhotoChosen(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = () => {
    state.profilePhoto = reader.result;
    document.getElementById('profilePhotoCircle').innerHTML = `<img src="${state.profilePhoto}" alt="Foto do perfil">`;
  };
  reader.readAsDataURL(file);
}
function updateProfileAgePreview() {
  const val = document.getElementById('profileBirthdate').value;
  const age = calcAge(val);
  const el = document.getElementById('profileAgePreview');
  el.textContent = age !== null ? `Idade: ${age} anos` : '';
}
