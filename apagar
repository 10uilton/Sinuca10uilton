function fichaNeededToWin() {
  // Quantas vitórias precisam para ganhar a série
  if (fichaState.bet === 1) return 1;
  if (fichaState.bet === 3) return 2; // melhor de 3
  if (fichaState.bet === 5) return 3; // melhor de 5
  return 1;
}

function fichaSerieDecided() {
  const needed = fichaNeededToWin();
  const remaining = fichaState.bet - fichaState.gamesPlayed;
  // Série decidida se alguém já ganhou 'needed' ou se o perdedor não pode mais alcançar
  if (fichaState.humanWins >= needed) return 'human';
  if (fichaState.aiWins >= needed) return 'ai';
  // Verificar se o perdedor ainda pode alcançar
  const humanCanReach = fichaState.humanWins + remaining >= needed;
  const aiCanReach = fichaState.aiWins + remaining >= needed;
  if (!humanCanReach) return 'ai';
  if (!aiCanReach) return 'human';
  return null; // série em aberto
}

function handleFichaGameEnd(humanWon) {
  fichaState.gamesPlayed++;
  if (humanWon) fichaState.humanWins++;
  else fichaState.aiWins++;

  const winner = fichaSerieDecided();
  if (winner) {
    // Série encerrada — acertar fichas
    if (winner === 'human') {
      addChips(fichaState.bet); // ganha as fichas da IA
      const msg = fichaState.bet === 1
        ? `Você ganhou a ficha! 🎟️ +${fichaState.bet}`
        : `Você venceu a série! 🎟️ +${fichaState.bet} fichas`;
      showToast(msg);
    } else {
      addChips(-fichaState.bet); // perde as fichas
      const msg = fichaState.bet === 1
        ? `A IA ganhou a ficha! 🎟️ -${fichaState.bet}`
        : `IA venceu a série! 🎟️ -${fichaState.bet} fichas`;
      showToast(msg);
    }
    fichaState.active = false;
    updateFichaBanner();
    return true; // série encerrada
  }
  updateFichaBanner();
  return false; // continua
}

