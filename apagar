// Nomes dos rounds do mata-mata conforme a quantidade de jogadores na chave
function champRoundNames(size) {
  const names = [];
  let n = size;
  while (n >= 2) {
    if (n === 2) names.push('Final');
    else if (n === 4) names.push('Semifinal');
    else if (n === 8) names.push('Quartas de Final');
    else if (n === 16) names.push('Oitavas de Final');
    else names.push('Primeira Fase');
    n = n / 2;
  }
  return names;
}

