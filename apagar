function renderCareer() {
  const map = document.getElementById('careerMap');
  map.innerHTML = cities.map((c, i) => {
    const locked = i > state.careerCity;
    const done = i < state.careerCity;
    const status = locked ? 'locked' : (done ? 'done' : 'current');
    const dotContent = done ? '✓' : (locked ? '🔒' : c.icon);
    return `<div class="city-marker ${status}" style="left:${c.x}%;top:${c.y}%" onclick="onCityMarkerClick(${i})">
      <div class="dot">${status==='current' ? '' : dotContent}</div>
      <div class="m-label">${c.name}</div>
    </div>`;
  }).join('');

  const progEl = document.getElementById('careerProgress');
  if (progEl) progEl.textContent = `${state.careerCity} / ${cities.length} cidades conquistadas`;

  const cardEl = document.getElementById('careerCurrentCard');
  if (cardEl) {
    if (state.careerCity >= cities.length) {
      cardEl.innerHTML = `<div class="city-icon">🏆</div><div class="city-info"><div class="city-name">Carreira concluída!</div><div class="city-state">Você venceu todas as ${cities.length} cidades</div></div>`;
    } else {
      const c = cities[state.careerCity];
      cardEl.innerHTML = `<div class="city-icon">${c.icon}</div>
        <div class="city-info">
          <div class="city-name">${c.name} <span style="color:#888;font-weight:400">· ${c.state}</span></div>
          <div class="city-state">${['','★','★★','★★★','★★★★','★★★★★'][c.difficulty]} · ${c.desc}</div>
          <div class="city-reward">💵 +R$ ${c.reward.toLocaleString()}</div>
        </div>
        <button class="go-btn" onclick="startCareerMatch(${state.careerCity})">JOGAR</button>`;
    }
  }
}
function onCityMarkerClick(i) {
  if (i > state.careerCity) { showToast('🔒 Cidade bloqueada — vença a atual pra liberar'); return; }
  if (i < state.careerCity) { showToast(`✓ ${cities[i].name} já conquistada`); return; }
  startCareerMatch(i);
}
let currentCareerIdx = -1;
let currentCareerOpponentName = '';
function startCareerMatch(i) {
  if (i !== state.careerCity) return;
  if (state.chips <= 0) { showToast('Sem fichas! Compre na Loja 🎟️'); return; }
  addChips(-1);
  currentCareerIdx = i;
  currentCareerOpponentName = randomBrazilianName(newAiOpponentSet());
  currentGameContext = 'career';
  aiDifficulty = 'hard'; // Carreira sempre difícil
  saveModeSession('career', { cityIdx: i });
  startGame('ai');
}

