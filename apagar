    hudMsg = isHuman ? '<img src="data:image/svg+xml;base64," alt="Bola 10" style="width:1em;height:1em;vertical-align:-0.15em;border-radius:50%;display:inline-block;"> Posicione a bola branca!' : 'IA posicionando...';
  } else {
    hudMsg = isHuman ? `Sua vez${chalkInfo}` : 'IA jogando...';
  }
  document.getElementById('hudMsg').innerHTML = hudMsg;
  document.getElementById('hudFouls').textContent = foulNextTurn ? '⚠️ Falta! Bola branca livre' : '';
}

function setShootEnabled(on) {
  document.getElementById('shootBtn').disabled = !on;
}

function renderBallIcons(elId, group) {
  const el = document.getElementById(elId);
  if (!el) return;
  if (group === -1) { el.innerHTML = ''; return; }

  const isSolidGroup = group === 0;
  // Filtrar bolas ainda ativas desse grupo
  const myBalls = balls.filter(b => b.active && (isSolidGroup ? isSolid(b.n) : isStripe(b.n)));

  el.innerHTML = myBalls.map(b => {
    const color = getBallColor(b.n);
    if (isSolidGroup) {
      return `<div class="hud-ball-dot" style="background:${color};border-color:rgba(255,255,255,0.3)" title="${b.n}"></div>`;
    } else {
      return `<div class="hud-ball-stripe" style="--stripe-color:${color}" title="${b.n}"></div>`;
    }
  }).join('');
}

// ===== DRAW =====
function renderStaticTable(ctx, effectiveTable) {
  const isBrazuka  = effectiveTable === 'mesa_brazuka';
  const isAzul     = effectiveTable === 'mesa_azul';
  const isPreta    = effectiveTable === 'mesa_preta';
  const isGraffiti = effectiveTable === 'mesa_graffiti';
  const isChopp    = effectiveTable === 'mesa_chopp';
  const isFutebol  = effectiveTable === 'mesa_futebol';

  // === FUNDO DA MESA (madeira externa) ===
  const woodOuterX = TL-28, woodOuterY = TT-28, woodOuterW = TR-TL+56, woodOuterH = TB-TT+56;

  // Sombra projetada da mesa inteira sobre o fundo (sensação de elevação/profundidade)
  ctx.save();
  ctx.shadowColor = 'rgba(0,0,0,0.6)';
  ctx.shadowBlur = 26;
  ctx.shadowOffsetX = 0;
  ctx.shadowOffsetY = 10;
  ctx.fillStyle = 'rgba(0,0,0,1)';
  ctx.beginPath();
  ctx.roundRect(woodOuterX, woodOuterY, woodOuterW, woodOuterH, 16);
  ctx.fill();
  ctx.restore();

  let woodGrad;
  if (isBrazuka) {
    // Madeira dourada — homenagem à Copa
    woodGrad = ctx.createLinearGradient(woodOuterX, woodOuterY, woodOuterX+woodOuterW, woodOuterY+woodOuterH);
    woodGrad.addColorStop(0,    '#c8860a');
    woodGrad.addColorStop(0.25, '#e8a800');
    woodGrad.addColorStop(0.5,  '#f0c040');
    woodGrad.addColorStop(0.75, '#d4950c');
    woodGrad.addColorStop(1,    '#a06800');
  } else if (isPreta) {
    woodGrad = ctx.createLinearGradient(woodOuterX, woodOuterY, woodOuterX+woodOuterW, woodOuterY+woodOuterH);
    woodGrad.addColorStop(0, '#2a2a2a'); woodGrad.addColorStop(0.5, '#111'); woodGrad.addColorStop(1, '#0a0a0a');
  } else if (isGraffiti) {
    // Moldura tipo muro branco urbano
    woodGrad = ctx.createLinearGradient(woodOuterX, woodOuterY, woodOuterX+woodOuterW, woodOuterY+woodOuterH);
    woodGrad.addColorStop(0,    '#f5f5f0');
    woodGrad.addColorStop(0.3,  '#e8e8e2');
    woodGrad.addColorStop(0.6,  '#dcdcd5');
    woodGrad.addColorStop(1,    '#c8c8c0');
  } else if (isChopp) {
    // Madeira escura de boteco
    woodGrad = ctx.createLinearGradient(woodOuterX, woodOuterY, woodOuterX+woodOuterW, woodOuterY+woodOuterH);
    woodGrad.addColorStop(0,    '#3b1a08');
    woodGrad.addColorStop(0.25, '#2a1005');
    woodGrad.addColorStop(0.55, '#1e0c03');
    woodGrad.addColorStop(0.8,  '#2a1005');
    woodGrad.addColorStop(1,    '#150800');
  } else if (isFutebol) {
    // Grama sintética da arquibancada ao redor do campo
    woodGrad = ctx.createLinearGradient(woodOuterX, woodOuterY, woodOuterX+woodOuterW, woodOuterY+woodOuterH);
    woodGrad.addColorStop(0,    '#1b5e20');
    woodGrad.addColorStop(0.3,  '#276b2b');
    woodGrad.addColorStop(0.6,  '#1d5722');
    woodGrad.addColorStop(1,    '#123f16');
  } else {
    woodGrad = ctx.createLinearGradient(woodOuterX, woodOuterY, woodOuterX+woodOuterW, woodOuterY+woodOuterH);
    woodGrad.addColorStop(0,    '#a85a1f');
    woodGrad.addColorStop(0.25, '#8a3f12');
    woodGrad.addColorStop(0.55, '#6e2e0c');
    woodGrad.addColorStop(0.8,  '#8a3f12');
    woodGrad.addColorStop(1,    '#5c2408');
  }
  ctx.fillStyle = woodGrad;
  ctx.beginPath();
  ctx.roundRect(woodOuterX, woodOuterY, woodOuterW, woodOuterH, 16);
  ctx.fill();

  // Veios de madeira (ou textura de tijolo/concreto na graffiti)
  ctx.save();
  ctx.beginPath();
  ctx.roundRect(woodOuterX, woodOuterY, woodOuterW, woodOuterH, 16);
  ctx.clip();
  if (isGraffiti) {
    // Textura de tijolo/concreto
    ctx.strokeStyle = 'rgba(0,0,0,0.28)';
    ctx.lineWidth = 1.2;
    const brickH = 11;
    let rowIdx = 0;
    for (let gy = woodOuterY; gy < woodOuterY + woodOuterH; gy += brickH) {
      ctx.beginPath(); ctx.moveTo(woodOuterX, gy); ctx.lineTo(woodOuterX+woodOuterW, gy); ctx.stroke();
      const offset = (rowIdx % 2 === 0) ? 0 : 18;
      for (let gx = woodOuterX - 18 + offset; gx < woodOuterX + woodOuterW; gx += 36) {
        ctx.beginPath(); ctx.moveTo(gx, gy); ctx.lineTo(gx, gy+brickH); ctx.stroke();
      }
      rowIdx++;
    }
    // Manchas douradas/pretas sutis tipo respingo de tinta
    const stains = [[0.12,0.2,'rgba(240,192,64,0.18)'],[0.78,0.15,'rgba(10,10,10,0.10)'],[0.3,0.75,'rgba(10,10,10,0.10)'],[0.85,0.8,'rgba(240,192,64,0.16)']];
    stains.forEach(([fx,fy,col]) => {
      const sx2 = woodOuterX + woodOuterW*fx, sy2 = woodOuterY + woodOuterH*fy;
      const sg = ctx.createRadialGradient(sx2, sy2, 2, sx2, sy2, 26);
      sg.addColorStop(0, col); sg.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = sg;
      ctx.beginPath(); ctx.arc(sx2, sy2, 26, 0, Math.PI*2); ctx.fill();
    });
  } else {
  ctx.strokeStyle = isBrazuka ? 'rgba(255,255,255,0.12)' : isChopp ? 'rgba(255,200,100,0.08)' : isFutebol ? 'rgba(255,255,255,0.14)' : 'rgba(0,0,0,0.10)';
  for (let i = 0; i < 14; i++) {
    const gy = woodOuterY + (i+0.5) * (woodOuterH/14) + Math.sin(i*1.3)*3;
    ctx.lineWidth = 1 + (i%3===0 ? 0.6 : 0);
    ctx.beginPath();
    ctx.moveTo(woodOuterX, gy);
    ctx.bezierCurveTo(
      woodOuterX+woodOuterW*0.3, gy + Math.sin(i*0.7)*6,
      woodOuterX+woodOuterW*0.7, gy - Math.sin(i*0.9)*6,
      woodOuterX+woodOuterW, gy
    );
    ctx.stroke();
  }
  }
  ctx.restore();

  // Bisel 3D do quadro de madeira
  ctx.save();
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.roundRect(woodOuterX+1.5, woodOuterY+1.5, woodOuterW-3, woodOuterH-3, 15);
  ctx.strokeStyle = isBrazuka ? 'rgba(255,240,160,0.55)' : (isGraffiti ? 'rgba(0,0,0,0.4)' : isFutebol ? 'rgba(255,255,255,0.5)' : 'rgba(255,210,140,0.35)');
  ctx.stroke();
  ctx.beginPath();
  ctx.roundRect(woodOuterX+2.5, woodOuterY+2.5, woodOuterW-7, woodOuterH-7, 14);
  ctx.strokeStyle = 'rgba(0,0,0,0.35)';
  ctx.stroke();
  ctx.restore();

  // Friso decorativo entre a madeira e o trilho
  ctx.strokeStyle = isBrazuka ? 'rgba(0,156,59,0.9)' : (isGraffiti ? 'rgba(240,192,64,0.9)' : isChopp ? 'rgba(200,134,10,0.8)' : isFutebol ? 'rgba(255,255,255,0.85)' : 'rgba(240,192,64,0.55)');
  ctx.lineWidth = isBrazuka ? 2.5 : (isGraffiti ? 2.5 : isChopp ? 2.2 : isFutebol ? 2.2 : 1.4);
  ctx.beginPath();
  ctx.roundRect(TL-17, TT-17, TR-TL+34, TB-TT+34, 11);
  ctx.stroke();

  // === TRILHO / CUSHION ===
  let railGrad;
  if (isBrazuka) {
    // Trilho azul CBF
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0,   '#002776');
    railGrad.addColorStop(0.5, '#003a99');
    railGrad.addColorStop(1,   '#001855');
  } else if (isPreta) {
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0, '#1a1a1a'); railGrad.addColorStop(1, '#0d0d0d');
  } else if (isAzul) {
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0, '#0d2a5c'); railGrad.addColorStop(0.5, '#1565c0'); railGrad.addColorStop(1, '#0a1e48');
  } else if (isGraffiti) {
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0,   '#161616');
    railGrad.addColorStop(0.5, '#0d0d0d');
    railGrad.addColorStop(1,   '#000000');
  } else if (isChopp) {
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0,   '#3b1a08');
    railGrad.addColorStop(0.5, '#2a1005');
    railGrad.addColorStop(1,   '#1e0c03');
  } else if (isFutebol) {
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0,   '#fafafa');
    railGrad.addColorStop(0.5, '#e4e4e0');
    railGrad.addColorStop(1,   '#c8c8c2');
  } else {
    railGrad = ctx.createLinearGradient(TL-16, TT-16, TR+16, TB+16);
    railGrad.addColorStop(0,    '#0e4a20');
    railGrad.addColorStop(0.5,  '#176b30');
    railGrad.addColorStop(1,    '#0a3a18');
  }
  ctx.fillStyle = railGrad;
  ctx.beginPath();
  ctx.roundRect(TL-16, TT-16, TR-TL+32, TB-TT+32, 10);
  ctx.fill();

  // Realce do trilho (luz vindo de cima-esquerda)
  ctx.save();
  ctx.beginPath();
  ctx.roundRect(TL-16, TT-16, TR-TL+32, TB-TT+32, 10);
  ctx.clip();
  const railShine = ctx.createLinearGradient(TL-16, TT-16, TL-2, TT-2);
  railShine.addColorStop(0, 'rgba(255,255,255,0.0)');
  railShine.addColorStop(1, isGraffiti ? 'rgba(240,192,64,0.22)' : 'rgba(255,255,255,0.16)');
  ctx.fillStyle = railShine;
  ctx.beginPath();
  ctx.roundRect(TL-16, TT-16, TR-TL+32, TB-TT+32, 10);
  ctx.fill();

  // Volume de "almofada" — brilho fino ao longo da borda externa superior
  ctx.strokeStyle = isGraffiti ? 'rgba(240,192,64,0.5)' : 'rgba(255,255,255,0.30)';
  ctx.lineWidth = 2.5;
  ctx.beginPath();
  ctx.roundRect(TL-15, TT-15, TR-TL+30, TB-TT+30, 9);
  ctx.stroke();

  // Sombra escura fina junto à borda interna (onde a almofada desce para o feltro)
  ctx.strokeStyle = 'rgba(0,0,0,0.45)';
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.roundRect(TL-3.5, TT-3.5, TR-TL+7, TB-TT+7, 5);
  ctx.stroke();
  ctx.restore();

  // Contorno dourado extra no trilho (graffiti)
  if (isGraffiti) {
    ctx.save();
    ctx.beginPath();
    ctx.roundRect(TL-15, TT-15, TR-TL+30, TB-TT+30, 9);
    ctx.strokeStyle = 'rgba(240,192,64,0.6)';
    ctx.lineWidth = 1.4;
    ctx.stroke();
    ctx.restore();
  }

  // === DIAMANTES DE MIRA ===
  const drawDiamond = (dx, dy, s) => {
    ctx.save();
    ctx.beginPath();
    ctx.moveTo(dx, dy-s); ctx.lineTo(dx+s*0.62, dy); ctx.lineTo(dx, dy+s); ctx.lineTo(dx-s*0.62, dy);
    ctx.closePath();
    const dGrad = ctx.createLinearGradient(dx, dy-s, dx, dy+s);
    if (isBrazuka) {
      dGrad.addColorStop(0, '#fffbe0');
      dGrad.addColorStop(1, '#f0c040');
    } else if (isFutebol) {
      dGrad.addColorStop(0, '#ffffff');
      dGrad.addColorStop(1, '#c7cdd1');
    } else {
      dGrad.addColorStop(0, '#fff6d8');
      dGrad.addColorStop(1, '#d8b860');
    }
    ctx.fillStyle = dGrad;
    ctx.fill();
    ctx.strokeStyle = 'rgba(0,0,0,0.4)';
    ctx.lineWidth = 0.6;
    ctx.stroke();
    ctx.restore();
  };
  const railMidDepthX = TL - 9, railMidDepthXr = TR + 9, railMidDepthY = TT - 9, railMidDepthYb = TB + 9;
  const midLeftY = pockets[2].y, midRightY = pockets[3].y;
  [1/3, 2/3].forEach(f => {
    drawDiamond(TL + (TR-TL)*f, railMidDepthY, 4.5);
    drawDiamond(TL + (TR-TL)*f, railMidDepthYb, 4.5);
  });
  [1/3, 2/3].forEach(f => {
    drawDiamond(railMidDepthX,  TT + (midLeftY-TT)*f, 4.5);
    drawDiamond(railMidDepthX,  midLeftY + (TB-midLeftY)*f, 4.5);
    drawDiamond(railMidDepthXr, TT + (midRightY-TT)*f, 4.5);
    drawDiamond(railMidDepthXr, midRightY + (TB-midRightY)*f, 4.5);
  });

  // Linha de separação trilho/feltro
  ctx.strokeStyle = 'rgba(0,0,0,0.55)';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.roundRect(TL-2, TT-2, TR-TL+4, TB-TT+4, 4);
  ctx.stroke();
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.roundRect(TL-0.5, TT-0.5, TR-TL+1, TB-TT+1, 3);
  ctx.stroke();

  // === FELTRO ===
  const feltW = TR - TL;
  const feltH = TB - TT;
  const cx = (TL+TR)/2, cy = (TT+TB)/2;

  ctx.save();
  ctx.beginPath();
  ctx.roundRect(TL, TT, feltW, feltH, 3);
  ctx.clip();

  if (isBrazuka) {
    // Fundo verde
    const feltGreen = ctx.createRadialGradient(cx, TT+feltH*0.38, 10, cx, cy, Math.max(feltW,feltH)*0.75);
    feltGreen.addColorStop(0, '#009c3b');
    feltGreen.addColorStop(0.5, '#007a2e');
    feltGreen.addColorStop(1, '#005a20');
    ctx.fillStyle = feltGreen;
    ctx.fillRect(TL, TT, feltW, feltH);

    // Losango amarelo
    ctx.beginPath();
    ctx.moveTo(cx,             TT + feltH*0.07);   // topo
    ctx.lineTo(TL + feltW*0.94, cy);               // direita
    ctx.lineTo(cx,             TB - feltH*0.07);   // baixo
    ctx.lineTo(TL + feltW*0.06, cy);               // esquerda
    ctx.closePath();
    const diamondGrad = ctx.createRadialGradient(cx, cy, 10, cx, cy, feltW*0.5);
    diamondGrad.addColorStop(0, '#fedf00');
    diamondGrad.addColorStop(0.7, '#f0c800');
    diamondGrad.addColorStop(1, '#c8a000');
    ctx.fillStyle = diamondGrad;
    ctx.fill();

    // Círculo azul CBF
    const circleR = Math.min(feltW, feltH) * 0.25;
    ctx.beginPath();
    ctx.arc(cx, cy, circleR, 0, Math.PI*2);
    const blueGrad = ctx.createRadialGradient(cx-circleR*0.2, cy-circleR*0.2, 2, cx, cy, circleR);
    blueGrad.addColorStop(0, '#003ea8');
    blueGrad.addColorStop(0.6, '#002776');
    blueGrad.addColorStop(1, '#001555');
    ctx.fillStyle = blueGrad;
    ctx.fill();

    // Tudo que vai sobre o globo (faixa + texto + estrelas) fica preso
    // dentro do círculo azul, exatamente como na bandeira real.
    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, circleR, 0, Math.PI*2);
    ctx.clip();

    // Faixa branca "ORDEM E PROGRESSO"
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(-0.1);
    const faixaH = circleR * 0.28;
    ctx.fillStyle = '#fff';
    ctx.fillRect(-circleR * 1.1, -faixaH/2, circleR * 2.2, faixaH);

    // Texto na faixa
    ctx.fillStyle = '#003ea8';
    ctx.font = `bold ${Math.max(6, circleR*0.13)}px Arial`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText('ORDEM E PROGRESSO', 0, 0);
    ctx.restore();

    // Estrelas no círculo (5 estrelas simplificadas), presas ao clip do globo
    const drawStar5 = (sx, sy, r) => {
      ctx.save();
      ctx.translate(sx, sy);
      ctx.fillStyle = '#fff';
      ctx.beginPath();
      for (let i=0; i<5; i++) {
        const a = (i*4*Math.PI/5) - Math.PI/2;
        const ia = (i*4*Math.PI/5) - Math.PI/2 + Math.PI/5;
        if (i===0) ctx.moveTo(Math.cos(a)*r, Math.sin(a)*r);
        else ctx.lineTo(Math.cos(a)*r, Math.sin(a)*r);
        ctx.lineTo(Math.cos(ia)*r*0.38, Math.sin(ia)*r*0.38);
      }
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    };
    const sr = circleR * 0.09;
    // Estrelas acima da faixa
    drawStar5(cx - circleR*0.38, cy - circleR*0.52, sr);
    drawStar5(cx + circleR*0.15, cy - circleR*0.58, sr);
    drawStar5(cx + circleR*0.52, cy - circleR*0.38, sr);
    // Estrelas abaixo
    drawStar5(cx - circleR*0.52, cy + circleR*0.30, sr);
    drawStar5(cx + circleR*0.45, cy + circleR*0.42, sr);

    ctx.restore(); // fim do clip do globo

    // Borda do círculo azul
    ctx.beginPath();
    ctx.arc(cx, cy, circleR, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(255,255,255,0.25)';
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Brilho sobre o feltro
    const brazShine = ctx.createLinearGradient(TL, TT, TL, TT + feltH * 0.3);
    brazShine.addColorStop(0, 'rgba(255,255,255,0.12)');
    brazShine.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = brazShine;
    ctx.fillRect(TL, TT, feltW, feltH);

  } else if (isGraffiti) {
    // --- FELTRO ESTILO MURO URBANO / GRAFFITI ---
    // Fundo escuro tipo asfalto/concreto pichado
    const feltDark = ctx.createRadialGradient(cx, TT+feltH*0.38, 10, cx, cy, Math.max(feltW,feltH)*0.75);
    feltDark.addColorStop(0, '#f7f7f2');
    feltDark.addColorStop(0.5, '#ededE6');
    feltDark.addColorStop(1, '#dddcd2');
    ctx.fillStyle = feltDark;
    ctx.fillRect(TL, TT, feltW, feltH);

    // Textura de parede (riscos finos diagonais, tipo spray fosco)
    ctx.strokeStyle = 'rgba(0,0,0,0.035)';
    ctx.lineWidth = 1;
    for (let i = -feltH; i < feltW + feltH; i += 9) {
      ctx.beginPath(); ctx.moveTo(TL+i, TT); ctx.lineTo(TL+i+feltH, TT+feltH); ctx.stroke();
    }

    // Respingos / manchas de spray douradas e pretas
    const drips = [
      [0.10, 0.18, 34, 'rgba(240,192,64,0.35)'],
      [0.88, 0.12, 30, 'rgba(10,10,10,0.16)'],
      [0.06, 0.82, 28, 'rgba(10,10,10,0.16)'],
      [0.92, 0.86, 32, 'rgba(240,192,64,0.32)'],
      [0.50, 0.06, 22, 'rgba(240,192,64,0.20)'],
      [0.50, 0.94, 22, 'rgba(10,10,10,0.12)'],
    ];
    drips.forEach(([fx, fy, r, col]) => {
      const sx2 = TL + feltW*fx, sy2 = TT + feltH*fy;
      const sg = ctx.createRadialGradient(sx2, sy2, 1, sx2, sy2, r);
      sg.addColorStop(0, col);
      sg.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = sg;
      ctx.beginPath(); ctx.arc(sx2, sy2, r, 0, Math.PI*2); ctx.fill();
    });

    // "Pingos" de tinta escorrendo (drips) nas bordas, clássico do graffiti
    ctx.save();
    const dripColors = ['rgba(240,192,64,0.65)','rgba(10,10,10,0.5)','rgba(240,192,64,0.55)'];
    const dripSpots = [[0.18,'h'],[0.62,'h'],[0.35,'v'],[0.8,'v']];
    dripSpots.forEach(([f, axis], i) => {
      const col = dripColors[i % dripColors.length];
      ctx.fillStyle = col;
      if (axis === 'h') {
        const dx2 = TL + feltW*f, dripLen = 14 + (i*5)%10;
        ctx.beginPath();
        ctx.moveTo(dx2-3, TT);
        ctx.lineTo(dx2+3, TT);
        ctx.lineTo(dx2+1.5, TT+dripLen);
        ctx.quadraticCurveTo(dx2, TT+dripLen+4, dx2-1.5, TT+dripLen);
        ctx.closePath();
        ctx.fill();
      } else {
        const dy2 = TT + feltH*f, dripLen = 12 + (i*4)%10;
        ctx.beginPath();
        ctx.moveTo(TR-3, dy2-3);
        ctx.lineTo(TR-3, dy2+3);
        ctx.lineTo(TR-3-dripLen, dy2+1.5);
        ctx.quadraticCurveTo(TR-3-dripLen-4, dy2, TR-3-dripLen, dy2-1.5);
        ctx.closePath();
        ctx.fill();
      }
    });
    ctx.restore();

    // Coroa estilo graffiti no centro, agora toda dourada
    ctx.save();
    ctx.translate(cx, cy);
    const crownR = Math.min(feltW, feltH) * 0.16;
    ctx.shadowColor = 'rgba(0,0,0,0.35)';
    ctx.shadowBlur = 8;
    ctx.beginPath();
    ctx.moveTo(-crownR, crownR*0.35);
    ctx.lineTo(-crownR, -crownR*0.15);
    ctx.lineTo(-crownR*0.5, crownR*0.25);
    ctx.lineTo(-crownR*0.18, -crownR*0.55);
    ctx.lineTo(0, crownR*0.05);
    ctx.lineTo(crownR*0.18, -crownR*0.55);
    ctx.lineTo(crownR*0.5, crownR*0.25);
    ctx.lineTo(crownR, -crownR*0.15);
    ctx.lineTo(crownR, crownR*0.35);
    ctx.closePath();
    const crownGrad = ctx.createLinearGradient(0, -crownR*0.55, 0, crownR*0.35);
    crownGrad.addColorStop(0, '#fff3c4');
    crownGrad.addColorStop(0.5, '#f0c040');
    crownGrad.addColorStop(1, '#c89018');
    ctx.fillStyle = crownGrad;
    ctx.fill();
    ctx.shadowBlur = 0;
    ctx.strokeStyle = 'rgba(10,10,10,0.75)';
    ctx.lineWidth = 1.6;
    ctx.stroke();
    // Base da coroa
    ctx.beginPath();
    ctx.roundRect(-crownR, crownR*0.35, crownR*2, crownR*0.32, 2);
    const baseGrad = ctx.createLinearGradient(0, crownR*0.35, 0, crownR*0.67);
    baseGrad.addColorStop(0, '#d4a418');
    baseGrad.addColorStop(1, '#a87a0c');
    ctx.fillStyle = baseGrad;
    ctx.fill();
    ctx.strokeStyle = 'rgba(10,10,10,0.75)';
    ctx.stroke();
    ctx.restore();

    // Tag "10UILTON" estilo graffiti abaixo da coroa, em dourado com contorno preto
    ctx.save();
    ctx.translate(cx, cy + crownR*1.05);
    ctx.font = `900 ${Math.max(9, crownR*0.42)}px Orbitron, Arial`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.lineWidth = 3;
    ctx.strokeStyle = 'rgba(10,10,10,0.85)';
    ctx.strokeText('10UILTON', 0, 0);
    const tagGrad = ctx.createLinearGradient(-crownR, 0, crownR, 0);
    tagGrad.addColorStop(0, '#f0c040');
    tagGrad.addColorStop(0.5, '#fff3c4');
    tagGrad.addColorStop(1, '#f0c040');
    ctx.fillStyle = tagGrad;
    ctx.fillText('10UILTON', 0, 0);
    ctx.restore();

    // Brilho geral sobre o feltro
    const graffShine = ctx.createLinearGradient(TL, TT, TL, TT + feltH * 0.3);
    graffShine.addColorStop(0, 'rgba(255,255,255,0.35)');
    graffShine.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = graffShine;
    ctx.fillRect(TL, TT, feltW, feltH);

  } else if (isFutebol) {
    // --- FELTRO ESTILO GRAMADO DE CAMPO DE FUTEBOL ---
    const grassBase = ctx.createRadialGradient(cx, TT+feltH*0.38, 10, cx, cy, Math.max(feltW,feltH)*0.75);
    grassBase.addColorStop(0, '#3fae4a');
    grassBase.addColorStop(0.5, '#2f9440');
    grassBase.addColorStop(1, '#1f7a33');
    ctx.fillStyle = grassBase;
    ctx.fillRect(TL, TT, feltW, feltH);

    // Faixas de grama cortada (efeito "mowing stripes" transversal, como TV)
    const stripeH = feltH / 10;
    for (let i = 0; i < 10; i++) {
      if (i % 2 === 0) {
        ctx.fillStyle = 'rgba(255,255,255,0.06)';
        ctx.fillRect(TL, TT + i*stripeH, feltW, stripeH);
      }
    }

    // Brilho suave
    const grassShine = ctx.createLinearGradient(TL, TT, TL, TT + feltH * 0.35);
    grassShine.addColorStop(0, 'rgba(255,255,255,0.12)');
    grassShine.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = grassShine;
    ctx.fillRect(TL, TT, feltW, feltH);

  } else {
    if (isAzul) {
      fc0='#2196f3'; fc1='#1565c0'; fc2='#0d47a1'; fc3='#0a2a6e';
    } else if (isPreta) {
      fc0='#1a1a2e'; fc1='#0f0f1a'; fc2='#0a0a12'; fc3='#050508';
    } else if (isChopp) {
      fc0='#c8860a'; fc1='#a06808'; fc2='#7a5005'; fc3='#5c3a02';
    } else {
      fc0='#2bb04f'; fc1='#1f9540'; fc2='#157a30'; fc3='#0f5c24';
    }
    const feltGrad = ctx.createRadialGradient(cx, TT+feltH*0.38, 10, cx, cy, Math.max(feltW,feltH)*0.75);
    feltGrad.addColorStop(0, fc0);
    feltGrad.addColorStop(0.45, fc1);
    feltGrad.addColorStop(0.8, fc2);
    feltGrad.addColorStop(1, fc3);
    ctx.fillStyle = feltGrad;
    ctx.fillRect(TL, TT, feltW, feltH);

    // Textura do feltro (trama)
    ctx.strokeStyle = 'rgba(0,0,0,0.05)';
    ctx.lineWidth = 1;
    for (let i = -feltH; i < feltW + feltH; i += 10) {
      ctx.beginPath(); ctx.moveTo(TL+i, TT); ctx.lineTo(TL+i+feltH, TT+feltH); ctx.stroke();
    }
    ctx.strokeStyle = 'rgba(255,255,255,0.025)';
    for (let i = -feltH; i < feltW + feltH; i += 10) {
      ctx.beginPath(); ctx.moveTo(TL+i+5, TB); ctx.lineTo(TL+i+5-feltH, TT); ctx.stroke();
    }

    // Brilho suave
    const feltShine = ctx.createLinearGradient(TL, TT, TL, TT + feltH * 0.4);
    feltShine.addColorStop(0, 'rgba(255,255,255,0.1)');
    feltShine.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = feltShine;
    ctx.fillRect(TL, TT, feltW, feltH);
  }

  // Vinheta nas bordas (todas as mesas) — mais profunda para reforçar volume
  const feltVignette = ctx.createRadialGradient(
    cx, cy, Math.max(feltW,feltH)*0.38,
    cx, cy, Math.max(feltW,feltH)*0.74
  );
  feltVignette.addColorStop(0, 'rgba(0,0,0,0)');
  feltVignette.addColorStop(0.7, 'rgba(0,0,0,0.10)');
  feltVignette.addColorStop(1, 'rgba(0,0,0,0.32)');
  ctx.fillStyle = feltVignette;
  ctx.fillRect(TL, TT, feltW, feltH);

  // Sombra interna fina onde o feltro encontra o trilho (dá sensação de "cuba" rebaixada)
  ctx.save();
  ctx.lineWidth = 6;
  ctx.strokeStyle = 'rgba(0,0,0,0.28)';
  ctx.beginPath();
  ctx.roundRect(TL+3, TT+3, feltW-6, feltH-6, 2);
  ctx.stroke();
  ctx.lineWidth = 2;
  ctx.strokeStyle = 'rgba(0,0,0,0.18)';
  ctx.beginPath();
  ctx.roundRect(TL+0.5, TT+0.5, feltW-1, feltH-1, 2);
  ctx.stroke();
  ctx.restore();

  // Ball-in-hand zone indicator
  if (ballInHandMode && ballInHandRestricted) {
    const headLineY = TT + feltH * 0.70;
    ctx.save();
    ctx.fillStyle = 'rgba(240,192,64,0.08)';
    ctx.fillRect(TL, headLineY, feltW, TB - headLineY);
    ctx.strokeStyle = 'rgba(240,192,64,0.6)';
    ctx.lineWidth = 1.5;
    ctx.setLineDash([6, 6]);
    ctx.beginPath(); ctx.moveTo(TL+4, headLineY); ctx.lineTo(TR-4, headLineY); ctx.stroke();
    ctx.setLineDash([]);
    ctx.fillStyle = 'rgba(240,192,64,0.7)';
    ctx.font = '700 11px Rajdhani,Arial';
    ctx.textAlign = 'center';
    ctx.fillText('ÁREA DE SAÍDA', cx, headLineY - 6);
    ctx.restore();
  }

  ctx.restore(); // fim do clip do feltro

  // === MARCAÇÕES DA MESA ===
  if (isBrazuka) {
    ctx.strokeStyle = 'rgba(0,156,59,0.35)';
    ctx.lineWidth = 1;
    ctx.setLineDash([6, 10]);
    ctx.beginPath(); ctx.moveTo(TL+8, cy); ctx.lineTo(TR-8, cy); ctx.stroke();
    ctx.setLineDash([]);
    const headY = TT + feltH*0.78;
    ctx.strokeStyle = 'rgba(254,223,0,0.3)';
    ctx.setLineDash([4, 8]);
    ctx.beginPath(); ctx.moveTo(TL+8, headY); ctx.lineTo(TR-8, headY); ctx.stroke();
    ctx.setLineDash([]);
    ctx.beginPath(); ctx.arc(cx, headY, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(254,223,0,0.4)'; ctx.fill();
  } else if (isGraffiti) {
    // Linhas-guia em preto/dourado (sem medalhão — o centro já tem a coroa/tag do graffiti)
    ctx.strokeStyle = 'rgba(10,10,10,0.22)';
    ctx.lineWidth = 1; ctx.setLineDash([6,10]);
    ctx.beginPath(); ctx.moveTo(TL+8, cy); ctx.lineTo(TR-8, cy); ctx.stroke();
    ctx.setLineDash([]);
    const headY3 = TT + feltH*0.78;
    ctx.strokeStyle = 'rgba(240,192,64,0.5)'; ctx.lineWidth = 1; ctx.setLineDash([4,8]);
    ctx.beginPath(); ctx.moveTo(TL+8, headY3); ctx.lineTo(TR-8, headY3); ctx.stroke();
    ctx.setLineDash([]);
    ctx.beginPath(); ctx.arc(cx, headY3, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(240,192,64,0.6)'; ctx.fill();
    const footY3 = TT + BALL_R*2;
    ctx.beginPath(); ctx.arc(cx, footY3, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(10,10,10,0.3)'; ctx.fill();
  } else if (isFutebol) {
    // Linha de contorno do campo (linha lateral), logo dentro do feltro
    ctx.strokeStyle = 'rgba(255,255,255,0.85)';
    ctx.lineWidth = 2;
    ctx.strokeRect(TL+5, TT+5, feltW-10, feltH-10);

    // Linha do meio-campo
    ctx.beginPath(); ctx.moveTo(TL+5, cy); ctx.lineTo(TR-5, cy); ctx.stroke();

    // Círculo central + ponto central
    const centerR = Math.min(feltW, feltH) * 0.15;
    ctx.beginPath(); ctx.arc(cx, cy, centerR, 0, Math.PI*2); ctx.stroke();
    ctx.beginPath(); ctx.arc(cx, cy, 2.2, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(255,255,255,0.85)'; ctx.fill();

    // Grande área + semicírculo, no gol de cima e no gol de baixo
    const boxW = feltW * 0.52, boxH = feltH * 0.15;
    const arcR = boxW * 0.32;
    ctx.lineWidth = 2;
    ctx.strokeStyle = 'rgba(255,255,255,0.85)';

    ctx.strokeRect(cx - boxW/2, TT+5, boxW, boxH);
    ctx.beginPath(); ctx.arc(cx, TT+5+boxH, arcR, 0, Math.PI); ctx.stroke();

    ctx.strokeRect(cx - boxW/2, TB-5-boxH, boxW, boxH);
    ctx.beginPath(); ctx.arc(cx, TB-5-boxH, arcR, Math.PI, Math.PI*2); ctx.stroke();
  } else if (isChopp) {
    // Medalhão de boteco com caneco de chopp
    ctx.save();
    ctx.shadowColor = 'rgba(0,0,0,0.6)';
    ctx.shadowBlur = 8;
    ctx.beginPath(); ctx.arc(cx, cy, 32, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(200,134,10,0.8)'; ctx.lineWidth = 2.5; ctx.stroke();
    ctx.shadowBlur = 0;
    ctx.beginPath(); ctx.arc(cx, cy, 25, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(200,134,10,0.5)'; ctx.lineWidth = 1.5; ctx.stroke();
    const chopMedalGrad = ctx.createRadialGradient(cx, cy, 1, cx, cy, 22);
    chopMedalGrad.addColorStop(0, 'rgba(200,134,10,0.22)');
    chopMedalGrad.addColorStop(1, 'rgba(200,134,10,0.03)');
    ctx.beginPath(); ctx.arc(cx, cy, 22, 0, Math.PI*2);
    ctx.fillStyle = chopMedalGrad; ctx.fill();
    ctx.shadowColor = 'rgba(0,0,0,0.6)'; ctx.shadowBlur = 3;
    ctx.font = '22px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('🍺', cx, cy+1);
    ctx.restore();
    // Linhas-guia cor âmbar
    ctx.strokeStyle = 'rgba(200,134,10,0.3)';
    ctx.lineWidth = 1; ctx.setLineDash([6,10]);
    ctx.beginPath(); ctx.moveTo(TL+8, cy); ctx.lineTo(TR-8, cy); ctx.stroke();
    ctx.setLineDash([]);
    const headYc = TT + feltH*0.78;
    ctx.strokeStyle = 'rgba(200,134,10,0.35)'; ctx.lineWidth = 1; ctx.setLineDash([4,8]);
    ctx.beginPath(); ctx.moveTo(TL+8, headYc); ctx.lineTo(TR-8, headYc); ctx.stroke();
    ctx.setLineDash([]);
    ctx.beginPath(); ctx.arc(cx, headYc, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(200,134,10,0.5)'; ctx.fill();
    const footYc = TT + BALL_R*2;
    ctx.beginPath(); ctx.arc(cx, footYc, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(200,134,10,0.4)'; ctx.fill();
  } else {
    // Medalhão central padrão — bem mais destacado, com profundidade e brilho dourado
    ctx.save();
    // sombra suave por trás do medalhão (separa do feltro)
    ctx.shadowColor = 'rgba(0,0,0,0.5)';
    ctx.shadowBlur = 6;
    ctx.beginPath(); ctx.arc(cx, cy, 30, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(240,192,64,0.85)'; ctx.lineWidth = 2.2; ctx.stroke();
    ctx.shadowBlur = 0;

    ctx.beginPath(); ctx.arc(cx, cy, 24, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(240,192,64,0.55)'; ctx.lineWidth = 1.4; ctx.stroke();
    ctx.beginPath(); ctx.arc(cx, cy, 19, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(255,255,255,0.32)'; ctx.lineWidth = 1; ctx.stroke();

    // preenchimento sutil dentro do medalhão para destacar do feltro
    const medalGrad = ctx.createRadialGradient(cx, cy, 1, cx, cy, 19);
    medalGrad.addColorStop(0, 'rgba(240,192,64,0.18)');
    medalGrad.addColorStop(1, 'rgba(240,192,64,0.02)');
    ctx.beginPath(); ctx.arc(cx, cy, 19, 0, Math.PI*2);
    ctx.fillStyle = medalGrad;
    ctx.fill();

    // número "10" — bem mais nítido e dourado vivo
    ctx.shadowColor = 'rgba(0,0,0,0.55)';
    ctx.shadowBlur = 3;
    ctx.fillStyle = 'rgba(240,192,64,0.95)';
    ctx.font = '900 19px Orbitron, Arial';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText('10', cx, cy+1);
    ctx.restore();

    ctx.strokeStyle = 'rgba(255,255,255,0.12)';
    ctx.lineWidth = 1; ctx.setLineDash([6,10]);
    ctx.beginPath(); ctx.moveTo(TL+8, cy); ctx.lineTo(TR-8, cy); ctx.stroke();
    ctx.setLineDash([]);
    const headY2 = TT + feltH*0.78;
    ctx.strokeStyle = 'rgba(255,255,255,0.13)'; ctx.lineWidth = 1; ctx.setLineDash([4,8]);
    ctx.beginPath(); ctx.moveTo(TL+8, headY2); ctx.lineTo(TR-8, headY2); ctx.stroke();
    ctx.setLineDash([]);
    ctx.beginPath(); ctx.arc(cx, headY2, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(255,255,255,0.15)'; ctx.fill();
    const footY = TT + BALL_R*2;
    ctx.beginPath(); ctx.arc(cx, footY, 3, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(255,255,255,0.15)'; ctx.fill();
  }

  // === CAÇAPAS (pockets) — estilo 8 Ball Pool: bem escuras e profundas ===
  pockets.forEach((p, idx) => {
    const isMid = idx === 2 || idx === 3;
    const pR = isMid ? 8 : 10;

    // Sombra projetada no feltro ao redor da caçapa
    ctx.beginPath();
    ctx.arc(p.x + 2, p.y + 2, pR + 7, 0, Math.PI*2);
    const dropGrad = ctx.createRadialGradient(p.x+2, p.y+2, pR*0.6, p.x+2, p.y+2, pR+7);
    dropGrad.addColorStop(0, 'rgba(0,0,0,0.55)');
    dropGrad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = dropGrad;
    ctx.fill();

    // Aro externo de borracha/couro (jaw da caçapa)
    ctx.beginPath();
    ctx.arc(p.x, p.y, pR + 5.5, 0, Math.PI*2);
    const leatherGrad = ctx.createRadialGradient(p.x-3, p.y-3, 2, p.x, p.y, pR+5.5);
    leatherGrad.addColorStop(0, '#3a2410');
    leatherGrad.addColorStop(0.6, '#1c1208');
    leatherGrad.addColorStop(1, '#0a0603');
    ctx.fillStyle = leatherGrad;
    ctx.fill();

    // Aro metálico/dourado fino (acabamento)
    ctx.beginPath();
    ctx.arc(p.x, p.y, pR + 2.2, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(240,192,64,0.3)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Buraco da caçapa (bem escuro/profundo)
    ctx.beginPath();
    ctx.arc(p.x, p.y, pR, 0, Math.PI*2);
    const holeGrad = ctx.createRadialGradient(p.x, p.y, 1, p.x, p.y, pR);
    holeGrad.addColorStop(0, '#1a1a1a');
    holeGrad.addColorStop(0.5, '#080808');
    holeGrad.addColorStop(1, '#000000');
    ctx.fillStyle = holeGrad;
    ctx.fill();

    // Sombra interna no topo do buraco (profundidade)
    ctx.beginPath();
    ctx.arc(p.x, p.y, pR*0.94, Math.PI*1.0, Math.PI*2.0);
    ctx.strokeStyle = 'rgba(0,0,0,0.6)';
    ctx.lineWidth = 2;
    ctx.stroke();

    // Reflexo brilhante na borda (couro polido)
    ctx.beginPath();
    ctx.arc(p.x - pR*0.35, p.y - pR*0.4, pR*0.32, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(255,255,255,0.1)';
    ctx.fill();
  });
}

function draw() {
  ctx.clearRect(0, 0, W, H);

  // Campeonato sempre usa a Mesa Brazuka como palco oficial,
  // Carreira sempre usa a Mesa Futebol (palco temático de futebol),
  // Modo Ficha usa sempre a Mesa Chopp (palco do Bar 10uilton)
  // independente da mesa equipada na loja
  const effectiveTable = currentGameContext === 'champ'
    ? 'mesa_brazuka'
    : currentGameContext === 'career'
    ? 'mesa_futebol'
    : currentGameContext === 'ficha'
    ? 'mesa_chopp'
    : state.equippedTable;

  // Fundo/mesa estatico (madeira, trilho, feltro, marcacoes, cacapas) cacheado
  // num canvas offscreen; so re-renderiza quando a mesa ou o tamanho mudam,
  // em vez de redesenhar dezenas de gradientes a cada frame (era o principal
  // motivo da gameplay ficar pesada).
  const bgSig = effectiveTable + '|' + W + '|' + H + '|' + DPR;
  if (bgSig !== bgCacheSignature) {
    bgCanvas.width = Math.round(W * DPR); bgCanvas.height = Math.round(H * DPR);
    bgCtx.setTransform(DPR, 0, 0, DPR, 0, 0);
    renderStaticTable(bgCtx, effectiveTable);
    bgCacheSignature = bgSig;
  }
  ctx.drawImage(bgCanvas, 0, 0, W, H);
  // === TACO desenhado depois das bolas (por cima) — ver abaixo ===

  // Balls
  balls.forEach(b => {
    if (!b.active) return;
    drawBall(b);
  });

  // Ghost cue ball during ball-in-hand mode
  if (ballInHandMode && ballInHandGhostX !== null) {
    const gx = ballInHandGhostX, gy = ballInHandGhostY;
    ctx.save();

    // Sombra
    ctx.beginPath();
    ctx.ellipse(gx + 3, gy + BALL_R*0.5, BALL_R*1.05, BALL_R*0.38, 0, 0, Math.PI*2);
    ctx.fillStyle = 'rgba(0,0,0,0.35)';
    ctx.fill();

    // Corpo da bola com gradiente realista
    const ghostGrad = ctx.createRadialGradient(gx - BALL_R*0.3, gy - BALL_R*0.35, 1, gx, gy, BALL_R);
    ghostGrad.addColorStop(0, '#ffffff');
    ghostGrad.addColorStop(0.45, '#e8e8e8');
    ghostGrad.addColorStop(0.8, '#c0c0c0');
    ghostGrad.addColorStop(1, '#888888');
    ctx.beginPath();
    ctx.arc(gx, gy, BALL_R, 0, Math.PI*2);
    ctx.fillStyle = ghostGrad;
    ctx.fill();

    // Brilho
    const gloss = ctx.createRadialGradient(gx - BALL_R*0.32, gy - BALL_R*0.38, 0.5, gx, gy, BALL_R*0.7);
    gloss.addColorStop(0, 'rgba(255,255,255,0.85)');
    gloss.addColorStop(0.4, 'rgba(255,255,255,0.3)');
    gloss.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.beginPath();
    ctx.arc(gx, gy, BALL_R, 0, Math.PI*2);
    ctx.fillStyle = gloss;
    ctx.fill();

    // Anel dourado pulsante
    const pulse = 0.6 + 0.4 * Math.sin(frameCount * 0.12);
    ctx.beginPath();
    ctx.arc(gx, gy, BALL_R + 4, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(240,192,64,${pulse})`;
    ctx.lineWidth = 2.5;
    ctx.stroke();

    // Anel externo mais suave
    ctx.beginPath();
    ctx.arc(gx, gy, BALL_R + 9, 0, Math.PI*2);
    ctx.strokeStyle = `rgba(240,192,64,${pulse * 0.35})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    ctx.restore();
  }

  // === TACO por cima das bolas ===
  // === TACO (mira) ===
  if (!ballsMoving && cueBall.active && !ballInHandMode) {

    // === LINHA DE DIREÇÃO INTELIGENTE ===
    const dx = Math.cos(cueAngle);
    const dy = Math.sin(cueAngle);

    // Raycasting: detecta a primeira bola no caminho
    let hitBall = null;
    let hitDist = Infinity;
    let hitNx = 0, hitNy = 0; // normal de colisão

    balls.forEach(b => {
      if (!b.active || b.n === 0) return;
      // Vetor do cueBall ao centro da bola alvo
      const cx2 = b.x - cueBall.x;
      const cy2 = b.y - cueBall.y;
      // Projeção no eixo da mira
      const proj = cx2 * dx + cy2 * dy;
      if (proj <= 0) return; // atrás da branca
      // Distância perpendicular
      const perpDist2 = (cx2*cx2 + cy2*cy2) - proj*proj;
      const minDist = BALL_R * 2;
      if (perpDist2 >= minDist*minDist) return; // não intercepta
      // Distância real ao ponto de impacto
      const d = proj - Math.sqrt(minDist*minDist - perpDist2);
      if (d < 0) return;
      if (d < hitDist) {
        hitDist = d;
        hitBall = b;
        // Normal no ponto de colisão (da branca para a bola)
        const impX = cueBall.x + dx*d;
        const impY = cueBall.y + dy*d;
        const nLen = Math.sqrt((b.x-impX)**2 + (b.y-impY)**2) || 1;
        hitNx = (b.x - impX) / nLen;
        hitNy = (b.y - impY) / nLen;
      }
    });

    // Ponto de impacto (ou extremidade se não houver bola)
    const maxLen = Math.sqrt((TR-TL)**2 + (TB-TT)**2);
    const impX = cueBall.x + dx * (hitBall ? hitDist : maxLen);
    const impY = cueBall.y + dy * (hitBall ? hitDist : maxLen);

    // Clamp na borda da mesa se não houver bola
    let lineEndX = impX, lineEndY = impY;
    if (!hitBall) {
      lineEndX = Math.max(TL, Math.min(TR, impX));
      lineEndY = Math.max(TT, Math.min(TB, impY));
    }

    if (hitBall) {
      // --- Linha da branca até a bola (gradiente branco→dourado) ---
      const aimGrad = ctx.createLinearGradient(cueBall.x, cueBall.y, lineEndX, lineEndY);
      aimGrad.addColorStop(0, 'rgba(255,255,255,0.55)');
      aimGrad.addColorStop(1, 'rgba(240,192,64,0.85)');
      ctx.setLineDash([6, 7]);
      ctx.strokeStyle = aimGrad;
      ctx.lineWidth = 1.8;
      ctx.beginPath();
      ctx.moveTo(cueBall.x, cueBall.y);
      ctx.lineTo(lineEndX, lineEndY);
      ctx.stroke();
      ctx.setLineDash([]);

      // --- Círculo ghost no ponto de impacto (onde a branca vai tocar) ---
      ctx.save();
      ctx.globalAlpha = 0.45;
      ctx.beginPath();
      ctx.arc(lineEndX, lineEndY, BALL_R, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(240,192,64,0.9)';
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.restore();

      // --- Linha de deflexão da BOLA ALVO (na normal de colisão) ---
      const targetLineLen = 70;
      const targetEndX = hitBall.x + hitNx * targetLineLen;
      const targetEndY = hitBall.y + hitNy * targetLineLen;
      const targetGrad = ctx.createLinearGradient(hitBall.x, hitBall.y, targetEndX, targetEndY);
      targetGrad.addColorStop(0, 'rgba(240,192,64,1.0)');
      targetGrad.addColorStop(1, 'rgba(240,192,64,0.0)');
      ctx.setLineDash([5, 6]);
      ctx.strokeStyle = targetGrad;
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(hitBall.x, hitBall.y);
      ctx.lineTo(targetEndX, targetEndY);
      ctx.stroke();
      ctx.setLineDash([]);

      // Seta na ponta da linha da bola alvo
      const arrowSize = 6;
      const arrowAngle = Math.atan2(hitNy, hitNx);
      ctx.save();
      ctx.translate(targetEndX, targetEndY);
      ctx.rotate(arrowAngle);
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(-arrowSize, -arrowSize*0.55);
      ctx.lineTo(-arrowSize,  arrowSize*0.55);
      ctx.closePath();
      ctx.fillStyle = 'rgba(240,192,64,0.75)';
      ctx.fill();
      ctx.restore();

      // --- Linha de recuo da BRANCA (perpendicular à normal) ---
      // A branca se move na direção tangente após colisão elástica
      const cueBackLen = 50;
      // Componente tangente: retirar a componente normal de dx,dy
      const dotN = dx*hitNx + dy*hitNy;
      const tangX = dx - dotN*hitNx;
      const tangY = dy - dotN*hitNy;
      const tangLen = Math.sqrt(tangX*tangX + tangY*tangY) || 1;
      const cueBackEndX = lineEndX + (tangX/tangLen)*cueBackLen;
      const cueBackEndY = lineEndY + (tangY/tangLen)*cueBackLen;
      const cueGrad = ctx.createLinearGradient(lineEndX, lineEndY, cueBackEndX, cueBackEndY);
      cueGrad.addColorStop(0, 'rgba(255,255,255,0.65)');
      cueGrad.addColorStop(1, 'rgba(255,255,255,0.0)');
      ctx.setLineDash([4, 6]);
      ctx.strokeStyle = cueGrad;
      ctx.lineWidth = 1.4;
      ctx.beginPath();
      ctx.moveTo(lineEndX, lineEndY);
      ctx.lineTo(cueBackEndX, cueBackEndY);
      ctx.stroke();
      ctx.setLineDash([]);

      // Ponto de destaque na bola alvo (círculo colorido da bola no centro)
      ctx.save();
      ctx.globalAlpha = 0.7;
      ctx.beginPath();
      ctx.arc(hitBall.x, hitBall.y, BALL_R + 3, 0, Math.PI*2);
      ctx.strokeStyle = 'rgba(240,192,64,0.6)';
      ctx.lineWidth = 2;
      ctx.setLineDash([3,4]);
      ctx.stroke();
      ctx.setLineDash([]);
      ctx.restore();

    } else {
      // Sem bola no caminho: linha simples pontilhada até a borda
      ctx.setLineDash([5,9]);
      ctx.strokeStyle = 'rgba(255,255,255,0.22)';
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.moveTo(cueBall.x, cueBall.y);
      ctx.lineTo(lineEndX, lineEndY);
      ctx.stroke();
      ctx.setLineDash([]);

      // Ponto de impacto na borda
      ctx.beginPath();
      ctx.arc(lineEndX, lineEndY, 3, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(255,255,255,0.3)';
      ctx.fill();
    }

    // Ponto de impact (unused var placeholder removed)
    const ex = lineEndX;
    const ey = lineEndY;

    // === TACO REALISTA — COMPRIDO E DETALHADO ===
    const dist = 30 + power * 0.7;
    const cueLen = 230; // comprimento total visível

    const perpX = -Math.sin(cueAngle);
    const perpY =  Math.cos(cueAngle);

    // Pontos principais ao longo do eixo do taco (da ponta ao cabo)
    const tipX  = cueBall.x - Math.cos(cueAngle) * dist;
    const tipY  = cueBall.y - Math.sin(cueAngle) * dist;
    const buttX = cueBall.x - Math.cos(cueAngle) * (dist + cueLen);
    const buttY = cueBall.y - Math.sin(cueAngle) * (dist + cueLen);

    // Função auxiliar: ponto ao longo do taco (t=0 ponta, t=1 cabo)
    const along = (t) => ({
      x: tipX + (buttX - tipX) * t,
      y: tipY + (buttY - tipY) * t,
    });
    // Largura do taco em qualquer ponto (taper suave)
    const cueW = (t) => {
      // shaft fino -> forearm mais largo -> cabo largo (afinado pra proporção real de taco de sinuca)
      if (t < 0.15) return 0.9 + t * 3.3;          // shaft: 0.9 -> 1.4
      if (t < 0.45) return 1.4 + (t-0.15) * 4.4;   // forearm: 1.4 -> 2.7
      return 2.7 + (t-0.45) * 4.95;                 // cabo: 2.7 -> 5.4
    };

    // Estilo do taco equipado
    const cs = cueStyles[state.equippedCue] || cueStyles['taco_padrao'];

    // Desenha um segmento trapezoidal do taco entre t0 e t1
    const drawSegment = (t0, t1, fillStyle) => {
      const p0 = along(t0), p1 = along(t1);
      const w0 = cueW(t0), w1 = cueW(t1);
      ctx.beginPath();
      ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
      ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
      ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
      ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
      ctx.closePath();
      ctx.fillStyle = fillStyle;
      ctx.fill();
    };

    ctx.save();

    // === TACO DE BUTECO: visual único, simples e surrado ===
    if (state.equippedCue === 'taco_buteco') {
      // Sombra simples
      ctx.shadowColor = 'rgba(0,0,0,0.5)';
      ctx.shadowBlur = 7;
      ctx.shadowOffsetX = 3;
      ctx.shadowOffsetY = 5;

      // Taco inteiro de uma madeira só, desbotada, sem tapete fino
      // Shaft + forearm juntos (madeira barata, toda igual)
      {
        const p0 = along(0.04), p1 = along(0.60);
        const w0 = cueW(0.04), w1 = cueW(0.60);
        const shaftGr = ctx.createLinearGradient(
          p0.x + perpX*w0, p0.y + perpY*w0,
          p0.x - perpX*w0, p0.y - perpY*w0
        );
        shaftGr.addColorStop(0,    'rgba(0,0,0,0.0)');
        shaftGr.addColorStop(0.12, '#b89a58');
        shaftGr.addColorStop(0.42, '#c8aa68');
        shaftGr.addColorStop(0.70, '#b08840');
        shaftGr.addColorStop(0.88, '#8a6620');
        shaftGr.addColorStop(1,    'rgba(0,0,0,0.0)');
        ctx.beginPath();
        ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
        ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
        ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
        ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
        ctx.closePath();
        ctx.fillStyle = shaftGr;
        ctx.fill();

        // Riscos e arranhões na madeira — parece batido
        ctx.save();
        ctx.clip();
        ctx.strokeStyle = 'rgba(0,0,0,0.18)';
        ctx.lineWidth = 0.8;
        [0.28, 0.54, 0.76].forEach(fr => {
          ctx.beginPath();
          const ww0 = w0 * (fr-0.5)*1.8, ww1 = w1 * (fr-0.5)*1.8;
          ctx.moveTo(p0.x + perpX*ww0, p0.y + perpY*ww0);
          ctx.lineTo(p1.x + perpX*ww1, p1.y + perpY*ww1);
          ctx.stroke();
        });
        // Arranhão diagonal extra (uso e abuso)
        ctx.strokeStyle = 'rgba(0,0,0,0.12)';
        ctx.lineWidth = 1;
        const midP = along(0.28);
        const midW = cueW(0.28);
        ctx.beginPath();
        ctx.moveTo(midP.x + perpX*midW*0.3, midP.y + perpY*midW*0.3);
        ctx.lineTo(midP.x - perpX*midW*0.8, midP.y - perpY*midW*0.8 + 5);
        ctx.stroke();
        ctx.restore();
      }

      ctx.shadowBlur = 0; ctx.shadowOffsetX = 0; ctx.shadowOffsetY = 0;

      // Cabo: fita adesiva marrom enrolada (listras de fita)
      {
        const p0 = along(0.60), p1 = along(1.0);
        const w0 = cueW(0.60), w1 = cueW(1.0);
        // Base do cabo: plástico/madeira barata cinza
        const baseGr = ctx.createLinearGradient(
          p0.x + perpX*w0, p0.y + perpY*w0,
          p0.x - perpX*w0, p0.y - perpY*w0
        );
        baseGr.addColorStop(0, 'rgba(0,0,0,0)');
        baseGr.addColorStop(0.15, '#777');
        baseGr.addColorStop(0.50, '#999');
        baseGr.addColorStop(0.80, '#666');
        baseGr.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.beginPath();
        ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
        ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
        ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
        ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
        ctx.closePath();
        ctx.fillStyle = baseGr;
        ctx.fill();

        // Fita adesiva: listras diagonais beges/marrom
        ctx.save();
        ctx.beginPath();
        ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
        ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
        ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
        ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
        ctx.closePath();
        ctx.clip();
        const tapeStrips = 9;
        for (let g = 0; g < tapeStrips; g++) {
          const gt = 0.60 + (0.40 * g / tapeStrips);
          const gt2 = 0.60 + (0.40 * (g + 0.6) / tapeStrips);
          const gp0 = along(gt), gp1 = along(gt2);
          const gw0 = cueW(gt), gw1 = cueW(gt2);
          const tapeColor = (g % 2 === 0) ? 'rgba(190,160,100,0.72)' : 'rgba(150,120,70,0.55)';
          ctx.beginPath();
          ctx.moveTo(gp0.x + perpX*gw0, gp0.y + perpY*gw0);
          ctx.lineTo(gp0.x - perpX*gw0, gp0.y - perpY*gw0);
          ctx.lineTo(gp1.x - perpX*gw1, gp1.y - perpY*gw1);
          ctx.lineTo(gp1.x + perpX*gw1, gp1.y + perpY*gw1);
          ctx.closePath();
          ctx.fillStyle = tapeColor;
          ctx.fill();
          // Bordinha escura de cada tira de fita
          ctx.strokeStyle = 'rgba(80,50,20,0.3)';
          ctx.lineWidth = 0.8;
          ctx.stroke();
        }
        ctx.restore();
      }

      // Brilho geral (leve, já que o taco não tem laca boa)
      {
        const p0 = along(0.04), p1 = along(0.90);
        const w0 = cueW(0.04), w1 = cueW(0.90);
        const lacGr = ctx.createLinearGradient(
          p0.x + perpX*w0, p0.y + perpY*w0,
          p0.x - perpX*w0*0.3, p0.y - perpY*w0*0.3
        );
        lacGr.addColorStop(0,   'rgba(255,255,255,0.20)');
        lacGr.addColorStop(0.4, 'rgba(255,255,255,0.06)');
        lacGr.addColorStop(1,   'rgba(255,255,255,0.0)');
        ctx.beginPath();
        ctx.moveTo(p0.x + perpX*w0,      p0.y + perpY*w0);
        ctx.lineTo(p0.x + perpX*w0*0.3,  p0.y + perpY*w0*0.3);
        ctx.lineTo(p1.x + perpX*w1*0.3,  p1.y + perpY*w1*0.3);
        ctx.lineTo(p1.x + perpX*w1,      p1.y + perpY*w1);
        ctx.closePath();
        ctx.fillStyle = lacGr;
        ctx.fill();
      }

      // SEM anéis dourados — buteco não tem luxo

      // Ferrule gasta (cor encardida)
      {
        const fLen = 10;
        const fT = fLen / cueLen;
        const pF0 = along(0.0), pF1 = along(fT);
        const wF0 = cueW(0.0) * 1.05, wF1 = cueW(fT);
        const ferrGr = ctx.createLinearGradient(
          pF0.x + perpX*wF0, pF0.y + perpY*wF0,
          pF0.x - perpX*wF0, pF0.y - perpY*wF0
        );
        ferrGr.addColorStop(0,   '#888880');
        ferrGr.addColorStop(0.4, '#c0bcaa');
        ferrGr.addColorStop(0.7, '#b0ac98');
        ferrGr.addColorStop(1,   '#707060');
        ctx.beginPath();
        ctx.moveTo(pF0.x + perpX*wF0, pF0.y + perpY*wF0);
        ctx.lineTo(pF0.x - perpX*wF0, pF0.y - perpY*wF0);
        ctx.lineTo(pF1.x - perpX*wF1, pF1.y - perpY*wF1);
        ctx.lineTo(pF1.x + perpX*wF1, pF1.y + perpY*wF1);
        ctx.closePath();
        ctx.fillStyle = ferrGr;
        ctx.fill();
      }

      // Ponta gasta (desgastada, cor parda/encardida — não é azul bonita)
      {
        const tipR = cueW(0) * 1.08;
        ctx.beginPath();
        ctx.arc(tipX, tipY, tipR, 0, Math.PI*2);
        ctx.fillStyle = '#5a3a10';
        ctx.fill();
        const tipGr = ctx.createRadialGradient(tipX - perpX*tipR*0.3, tipY - perpY*tipR*0.3, 0, tipX, tipY, tipR);
        tipGr.addColorStop(0,   '#a07840');
        tipGr.addColorStop(0.5, '#7a5220');
        tipGr.addColorStop(1,   '#3a1a00');
        ctx.beginPath();
        ctx.arc(tipX, tipY, tipR * 0.90, 0, Math.PI*2);
        ctx.fillStyle = tipGr;
        ctx.fill();
        // lascado / irregular (sem brilho)
      }

      // Tampa do cabo: plástico barato cinza
      {
        const buttCapR = cueW(1.0) * 1.0;
        const bc = along(1.0);
        const bcGr = ctx.createRadialGradient(bc.x, bc.y, 0, bc.x, bc.y, buttCapR);
        bcGr.addColorStop(0,   '#aaa');
        bcGr.addColorStop(0.5, '#666');
        bcGr.addColorStop(1,   '#333');
        ctx.beginPath();
        ctx.arc(bc.x, bc.y, buttCapR, 0, Math.PI*2);
        ctx.fillStyle = bcGr;
        ctx.fill();
      }

      ctx.restore();
    } else {

    // --- Sombra do taco (mais profunda e difusa, reforça que o taco "flutua" sobre a mesa) ---
    ctx.shadowColor = 'rgba(0,0,0,0.65)';
    ctx.shadowBlur = 11;
    ctx.shadowOffsetX = 4;
    ctx.shadowOffsetY = 6;

    // --- 1. SHAFT (madeira clara) ---
    {
      const p0 = along(0.04), p1 = along(0.42);
      const w0 = cueW(0.04), w1 = cueW(0.42);
      const shaftGr = ctx.createLinearGradient(
        p0.x + perpX*w0, p0.y + perpY*w0,
        p0.x - perpX*w0, p0.y - perpY*w0
      );
      const sc = cs.shaft;
      shaftGr.addColorStop(0,    'rgba(255,255,255,0.0)');
      shaftGr.addColorStop(0.18, sc);
      shaftGr.addColorStop(0.45, sc);
      shaftGr.addColorStop(0.72, sc);
      shaftGr.addColorStop(0.88, sc);
      shaftGr.addColorStop(1,    'rgba(0,0,0,0.0)');
      ctx.beginPath();
      ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
      ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
      ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
      ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
      ctx.closePath();
      ctx.fillStyle = shaftGr;
      ctx.fill();

      // Veio de madeira sutil (linhas longitudinais finas, acompanham o taper)
      ctx.save();
      ctx.clip();
      ctx.strokeStyle = 'rgba(0,0,0,0.10)';
      ctx.lineWidth = 0.7;
      [0.3, 0.55, 0.78].forEach(fr => {
        ctx.beginPath();
        const a0 = along(0.04), a1 = along(0.42);
        const ww0 = w0 * (fr-0.5)*1.8, ww1 = w1 * (fr-0.5)*1.8;
        ctx.moveTo(a0.x + perpX*ww0, a0.y + perpY*ww0);
        ctx.lineTo(a1.x + perpX*ww1, a1.y + perpY*ww1);
        ctx.stroke();
      });
      ctx.restore();
    }

    ctx.shadowBlur = 0; ctx.shadowOffsetX = 0; ctx.shadowOffsetY = 0;

    // --- 2. FOREARM (madeira escura, mogno) ---
    {
      const p0 = along(0.42), p1 = along(0.62);
      const w0 = cueW(0.42), w1 = cueW(0.62);
      const fgGr = ctx.createLinearGradient(
        p0.x + perpX*w0, p0.y + perpY*w0,
        p0.x - perpX*w0, p0.y - perpY*w0
      );
      const fc = cs.forearm;
      fgGr.addColorStop(0,    'rgba(0,0,0,0.0)');
      fgGr.addColorStop(0.15, fc);
      fgGr.addColorStop(0.42, fc);
      fgGr.addColorStop(0.65, fc);
      fgGr.addColorStop(0.82, fc);
      fgGr.addColorStop(1,    'rgba(0,0,0,0.0)');
      ctx.beginPath();
      ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
      ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
      ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
      ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
      ctx.closePath();
      ctx.fillStyle = fgGr;
      ctx.fill();

      // Veio de madeira do forearm (tom mais escuro, mogno)
      ctx.save();
      ctx.clip();
      ctx.strokeStyle = 'rgba(0,0,0,0.16)';
      ctx.lineWidth = 0.7;
      [0.32, 0.62, 0.85].forEach(fr => {
        ctx.beginPath();
        const ww0 = w0 * (fr-0.5)*1.8, ww1 = w1 * (fr-0.5)*1.8;
        ctx.moveTo(p0.x + perpX*ww0, p0.y + perpY*ww0);
        ctx.lineTo(p1.x + perpX*ww1, p1.y + perpY*ww1);
        ctx.stroke();
      });
      ctx.restore();
    }

    // --- 3. CABO / GRIP (borracha escura com textura) ---
    {
      const p0 = along(0.62), p1 = along(1.0);
      const w0 = cueW(0.62), w1 = cueW(1.0);
      const bGr = ctx.createLinearGradient(
        p0.x + perpX*w0, p0.y + perpY*w0,
        p0.x - perpX*w0, p0.y - perpY*w0
      );
      const bc = cs.butt;
      bGr.addColorStop(0,    'rgba(0,0,0,0.0)');
      bGr.addColorStop(0.12, bc);
      bGr.addColorStop(0.40, bc);
      bGr.addColorStop(0.65, bc);
      bGr.addColorStop(0.85, bc);
      bGr.addColorStop(1,    'rgba(0,0,0,0.0)');
      ctx.beginPath();
      ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
      ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
      ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
      ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
      ctx.closePath();
      ctx.fillStyle = bGr;
      ctx.fill();

      // Textura de grip (linhas diagonais leves)
      ctx.save();
      ctx.beginPath();
      ctx.moveTo(p0.x + perpX*w0, p0.y + perpY*w0);
      ctx.lineTo(p0.x - perpX*w0, p0.y - perpY*w0);
      ctx.lineTo(p1.x - perpX*w1, p1.y - perpY*w1);
      ctx.lineTo(p1.x + perpX*w1, p1.y + perpY*w1);
      ctx.closePath();
      ctx.clip();
      ctx.strokeStyle = 'rgba(255,255,255,0.06)';
      ctx.lineWidth = 1.5;
      for (let g = 0; g < 20; g++) {
        const gt = 0.62 + (0.38 * g / 20);
        const gp = along(gt);
        const gw = cueW(gt);
        ctx.beginPath();
        ctx.moveTo(gp.x + perpX*gw, gp.y + perpY*gw - 1);
        ctx.lineTo(gp.x - perpX*gw, gp.y - perpY*gw + 1);
        ctx.stroke();
      }
      ctx.restore();
    }

    // --- 4. Brilho de laca sobre tudo (highlight longitudinal) ---
    {
      const p0 = along(0.04), p1 = along(0.90);
      const w0 = cueW(0.04), w1 = cueW(0.90);
      const lacGr = ctx.createLinearGradient(
        p0.x + perpX*w0, p0.y + perpY*w0,
        p0.x - perpX*w0*0.2, p0.y - perpY*w0*0.2
      );
      lacGr.addColorStop(0,   'rgba(255,255,255,0.42)');
      lacGr.addColorStop(0.35,'rgba(255,255,255,0.16)');
      lacGr.addColorStop(1,   'rgba(255,255,255,0.0)');
      ctx.beginPath();
      ctx.moveTo(p0.x + perpX*w0,       p0.y + perpY*w0);
      ctx.lineTo(p0.x + perpX*w0*0.25,  p0.y + perpY*w0*0.25);
      ctx.lineTo(p1.x + perpX*w1*0.25,  p1.y + perpY*w1*0.25);
      ctx.lineTo(p1.x + perpX*w1,       p1.y + perpY*w1);
      ctx.closePath();
      ctx.fillStyle = lacGr;
      ctx.fill();

      // Sombra do lado oposto (reforça o volume cilíndrico do taco)
      const shadeGr = ctx.createLinearGradient(
        p0.x - perpX*w0, p0.y - perpY*w0,
        p0.x + perpX*w0*0.1, p0.y + perpY*w0*0.1
      );
      shadeGr.addColorStop(0,   'rgba(0,0,0,0.30)');
      shadeGr.addColorStop(0.4, 'rgba(0,0,0,0.10)');
      shadeGr.addColorStop(1,   'rgba(0,0,0,0.0)');
      ctx.beginPath();
      ctx.moveTo(p0.x - perpX*w0,       p0.y - perpY*w0);
      ctx.lineTo(p0.x - perpX*w0*0.25,  p0.y - perpY*w0*0.25);
      ctx.lineTo(p1.x - perpX*w1*0.25,  p1.y - perpY*w1*0.25);
      ctx.lineTo(p1.x - perpX*w1,       p1.y - perpY*w1);
      ctx.closePath();
      ctx.fillStyle = shadeGr;
      ctx.fill();
    }

    // --- 5. Anéis decorativos (joint rings) ---
    // Anel de junção shaft/forearm
    const drawRing = (t, thick, colors) => {
      const dt = thick / cueLen;
      const steps = colors.length;
      for (let s = 0; s < steps; s++) {
        const t0 = t + dt * (s / steps);
        const t1 = t + dt * ((s+1) / steps);
        drawSegment(t0, t1, colors[s]);
      }
    };

    // Anel de junção shaft-forearm (t≈0.42): preto/prata/prata/preto
    drawRing(0.408, 12, ['#111','#888','#ccc','#888','#111']);
    // Dois anéis decorativos no forearm (t≈0.52 e 0.57): preto/ouro
    drawRing(0.510, 8,  ['#111','#c8a020','#f0c040','#c8a020','#111']);
    drawRing(0.555, 8,  ['#111','#c8a020','#f0c040','#c8a020','#111']);
    // Anel de junção forearm-cabo (t≈0.62): prata grosso
    drawRing(0.610, 14, ['#111','#666','#aaa','#eee','#aaa','#666','#111']);

    // --- 6. FERRULE (manga de marfim logo antes da ponta) ---
    {
      const fLen = 10; // px
      const fT = fLen / cueLen;
      const pFErr0 = along(0.0), pFErr1 = along(fT);
      const wF0 = cueW(0.0) * 1.05, wF1 = cueW(fT) * 1.0;
      const ferrGr = ctx.createLinearGradient(
        pFErr0.x + perpX*wF0, pFErr0.y + perpY*wF0,
        pFErr0.x - perpX*wF0, pFErr0.y - perpY*wF0
      );
      ferrGr.addColorStop(0,    '#b0b0a0');
      ferrGr.addColorStop(0.35, '#f0efe0');
      ferrGr.addColorStop(0.6,  '#e8e6d4');
      ferrGr.addColorStop(1,    '#9a9888');
      ctx.beginPath();
      ctx.moveTo(pFErr0.x + perpX*wF0, pFErr0.y + perpY*wF0);
      ctx.lineTo(pFErr0.x - perpX*wF0, pFErr0.y - perpY*wF0);
      ctx.lineTo(pFErr1.x - perpX*wF1, pFErr1.y - perpY*wF1);
      ctx.lineTo(pFErr1.x + perpX*wF1, pFErr1.y + perpY*wF1);
      ctx.closePath();
      ctx.fillStyle = ferrGr;
      ctx.fill();
      // borda escura inferior da ferrule
      ctx.strokeStyle = 'rgba(0,0,0,0.5)';
      ctx.lineWidth = 0.8;
      ctx.stroke();
    }

    // --- 7. PONTA AZUL (leather tip) ---
    {
      const tipR = cueW(0) * 1.08;
      // base escura
      ctx.beginPath();
      ctx.arc(tipX, tipY, tipR, 0, Math.PI*2);
      ctx.fillStyle = '#0d2a6e';
      ctx.fill();
      // face azul com gradiente 3D
      const tipGr = ctx.createRadialGradient(tipX - perpX*tipR*0.3, tipY - perpY*tipR*0.3, 0, tipX, tipY, tipR);
      tipGr.addColorStop(0,   '#6699dd');
      tipGr.addColorStop(0.4, '#3366bb');
      tipGr.addColorStop(1,   '#0d2255');
      ctx.beginPath();
      ctx.arc(tipX, tipY, tipR * 0.92, 0, Math.PI*2);
      ctx.fillStyle = tipGr;
      ctx.fill();
      // brilhinho na ponta
      ctx.beginPath();
      ctx.arc(tipX - perpX*tipR*0.25, tipY - perpY*tipR*0.25, tipR*0.32, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(180,210,255,0.45)';
      ctx.fill();
    }

    // --- 8. BUTT CAP (tampa do cabo) ---
    {
      const buttCapR = cueW(1.0) * 1.0;
      const bc = along(1.0);
      const bcGr = ctx.createRadialGradient(bc.x, bc.y, 0, bc.x, bc.y, buttCapR);
      bcGr.addColorStop(0,   '#888');
      bcGr.addColorStop(0.6, '#444');
      bcGr.addColorStop(1,   '#111');
      ctx.beginPath();
      ctx.arc(bc.x, bc.y, buttCapR, 0, Math.PI*2);
      ctx.fillStyle = bcGr;
      ctx.fill();
    }

    }

    ctx.restore();
  }
}

function renderBallShape(ctx, b, opts) {
  opts = opts || {};
  const stripe = isStripe(b.n);
  const isCue = b.n === 0;

  // Sombra projetada ampla (penumbra suave, dá sensação de elevação sobre o feltro)
  ctx.save();
  ctx.beginPath();
  ctx.ellipse(b.x + 5, b.y + b.r*0.62, b.r*1.5, b.r*0.62, 0, 0, Math.PI*2);
  const softShadow = ctx.createRadialGradient(b.x+5, b.y+b.r*0.62, 0, b.x+5, b.y+b.r*0.62, b.r*1.5);
  softShadow.addColorStop(0, 'rgba(0,0,0,0.22)');
  softShadow.addColorStop(0.7, 'rgba(0,0,0,0.10)');
  softShadow.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = softShadow;
  ctx.fill();
  ctx.restore();

  // Sombra de contato no feltro (achatada, mais escura e densa perto da bola — ponto de apoio)
  ctx.save();
  ctx.beginPath();
  ctx.ellipse(b.x + 3.5, b.y + b.r*0.55, b.r*1.05, b.r*0.42, 0, 0, Math.PI*2);
  const contactShadow = ctx.createRadialGradient(b.x+3.5, b.y+b.r*0.55, 0, b.x+3.5, b.y+b.r*0.55, b.r*1.05);
  contactShadow.addColorStop(0, 'rgba(0,0,0,0.62)');
  contactShadow.addColorStop(0.5, 'rgba(0,0,0,0.38)');
  contactShadow.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = contactShadow;
  ctx.fill();
  ctx.restore();

  // === BASE DA BOLA (esfera com iluminação vinda de cima-esquerda) ===
  const baseGrad = ctx.createRadialGradient(
    b.x - b.r*0.36, b.y - b.r*0.4, b.r*0.02,
    b.x + b.r*0.08, b.y + b.r*0.12, b.r*1.15
  );

  if (isCue) {
    baseGrad.addColorStop(0, '#ffffff');
    baseGrad.addColorStop(0.42, '#f6f6f6');
    baseGrad.addColorStop(0.74, '#d4d4d4');
    baseGrad.addColorStop(0.92, '#a4a4a4');
    baseGrad.addColorStop(1, '#767676');
  } else if (stripe) {
    baseGrad.addColorStop(0, '#ffffff');
    baseGrad.addColorStop(0.48, '#f3f3f3');
    baseGrad.addColorStop(0.78, '#d6d6d6');
    baseGrad.addColorStop(0.93, '#a8a8a8');
    baseGrad.addColorStop(1, '#7c7c7c');
  } else {
    baseGrad.addColorStop(0,    lightenColor(b.color, 105));
    baseGrad.addColorStop(0.28, lightenColor(b.color, 38));
    baseGrad.addColorStop(0.62, b.color);
    baseGrad.addColorStop(0.87, darkenColor(b.color, 58));
    baseGrad.addColorStop(1,    darkenColor(b.color, 92));
  }

  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.fillStyle = baseGrad;
  ctx.fill();

  // Faixa das listradas (com transição suave/penada para parecer "envolvida" na bola)
  if (stripe) {
    ctx.save();
    ctx.beginPath();
    ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
    ctx.clip();
    const bandHalf = b.r * 0.60;   // metade da faixa colorida cheia
    const feather  = b.r * 0.22;   // suavização da borda da faixa
    const span = b.r * 2;
    const o = (dy) => 0.5 + dy/span;
    const stripeGrad = ctx.createLinearGradient(b.x, b.y - b.r, b.x, b.y + b.r);
    stripeGrad.addColorStop(0, 'rgba(255,255,255,0)');
    stripeGrad.addColorStop(Math.max(0,o(-(bandHalf+feather))), 'rgba(255,255,255,0)');
    stripeGrad.addColorStop(o(-bandHalf), lightenColor(b.color, 35));
    stripeGrad.addColorStop(0.5, b.color);
    stripeGrad.addColorStop(o(bandHalf), darkenColor(b.color, 35));
    stripeGrad.addColorStop(Math.min(1,o(bandHalf+feather)), 'rgba(255,255,255,0)');
    stripeGrad.addColorStop(1, 'rgba(255,255,255,0)');
    ctx.fillStyle = stripeGrad;
    ctx.fillRect(b.x - b.r, b.y - b.r, b.r*2, b.r*2);
    // sombreamento esférico por cima da faixa, para acompanhar a curvatura da bola
    ctx.beginPath();
    ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
    ctx.fillStyle = baseGrad;
    ctx.globalCompositeOperation = 'multiply';
    ctx.globalAlpha = 0.18;
    ctx.fill();
    ctx.restore();
  }

  // Reflexo verde sutil do feltro da mesa (luz indireta refletindo por baixo)
  ctx.save();
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.clip();
  const feltBounce = ctx.createRadialGradient(
    b.x + b.r*0.25, b.y + b.r*0.62, 0,
    b.x + b.r*0.25, b.y + b.r*0.62, b.r*0.85
  );
  feltBounce.addColorStop(0, 'rgba(70,180,90,0.16)');
  feltBounce.addColorStop(1, 'rgba(70,180,90,0)');
  ctx.fillStyle = feltBounce;
  ctx.fill();
  ctx.restore();

  // Rim shadow — terminador escuro na borda oposta à luz, reforça a curvatura esférica
  ctx.save();
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.clip();
  const rimShadow = ctx.createRadialGradient(
    b.x - b.r*0.22, b.y - b.r*0.26, b.r*0.55,
    b.x + b.r*0.18, b.y + b.r*0.22, b.r*1.05
  );
  rimShadow.addColorStop(0, 'rgba(0,0,0,0)');
  rimShadow.addColorStop(0.72, 'rgba(0,0,0,0)');
  rimShadow.addColorStop(1, 'rgba(0,0,0,0.32)');
  ctx.fillStyle = rimShadow;
  ctx.fill();
  ctx.restore();

  // Fresnel de borda — escurecimento fino e uniforme em TODA a volta do contorno
  // (não só do lado da sombra). É o que faz o olho ler "esfera" em vez de
  // "círculo com gradiente": em ângulo rasante a luz reflete pra longe da
  // câmera em qualquer direção, então a borda inteira fica mais escura.
  ctx.save();
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.clip();
  const fresnel = ctx.createRadialGradient(b.x, b.y, b.r*0.72, b.x, b.y, b.r);
  fresnel.addColorStop(0, 'rgba(0,0,0,0)');
  fresnel.addColorStop(0.75, 'rgba(0,0,0,0.05)');
  fresnel.addColorStop(1, 'rgba(0,0,0,0.4)');
  ctx.fillStyle = fresnel;
  ctx.fill();
  ctx.restore();
  // Oclusão de contato — arco escuro colado na base da bola (onde "toca" o feltro),
  // reforça a sensação de peso/apoio além da sombra projetada solta no chão
  ctx.save();
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.clip();
  const contactAO = ctx.createRadialGradient(
    b.x, b.y + b.r*0.86, b.r*0.05,
    b.x, b.y + b.r*0.86, b.r*0.55
  );
  contactAO.addColorStop(0, 'rgba(0,0,0,0.38)');
  contactAO.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = contactAO;
  ctx.fill();
  ctx.restore();

  // Brilho principal (reflexo especular) — mais definido, efeito "vidro polido"
  const gloss = ctx.createRadialGradient(
    b.x - b.r*0.32, b.y - b.r*0.38, 0.5,
    b.x - b.r*0.18, b.y - b.r*0.22, b.r*0.72
  );
  gloss.addColorStop(0, 'rgba(255,255,255,0.88)');
  gloss.addColorStop(0.25, 'rgba(255,255,255,0.4)');
  gloss.addColorStop(0.65, 'rgba(255,255,255,0.08)');
  gloss.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.fillStyle = gloss;
  ctx.fill();

  // Reflexo alongado (streak), como se fosse o reflexo de uma janela/luz de teto —
  // dá aquele acabamento "premium" de bola de vidro/resina bem polida
  ctx.save();
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.clip();
  ctx.translate(b.x - b.r*0.28, b.y - b.r*0.5);
  ctx.rotate(-0.55);
  const streak = ctx.createLinearGradient(0, -b.r*0.5, 0, b.r*0.5);
  streak.addColorStop(0, 'rgba(255,255,255,0)');
  streak.addColorStop(0.5, 'rgba(255,255,255,0.55)');
  streak.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = streak;
  ctx.beginPath();
  ctx.ellipse(0, 0, b.r*0.13, b.r*0.5, 0, 0, Math.PI*2);
  ctx.fill();
  ctx.restore();

  // Reflexo secundário difuso (luz ambiente do ambiente/mesa, lado oposto ao brilho principal)
  const gloss2 = ctx.createRadialGradient(
    b.x + b.r*0.38, b.y + b.r*0.05, 0,
    b.x + b.r*0.38, b.y + b.r*0.05, b.r*0.5
  );
  gloss2.addColorStop(0, 'rgba(255,255,255,0.14)');
  gloss2.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.fillStyle = gloss2;
  ctx.fill();

  // Micro-ponto de luz (brilho de fonte de luz pontual, mais nítido e "molhado")
  const microGloss = ctx.createRadialGradient(
    b.x - b.r*0.4, b.y - b.r*0.44, 0,
    b.x - b.r*0.4, b.y - b.r*0.44, b.r*0.22
  );
  microGloss.addColorStop(0, 'rgba(255,255,255,1)');
  microGloss.addColorStop(0.45, 'rgba(255,255,255,0.4)');
  microGloss.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.fillStyle = microGloss;
  ctx.fill();

  // Núcleo ultra-brilhante — o "ponto quente" bem pequeno e duro que dá o
  // acabamento de resina/vidro polido (como uma bola de sinuca de verdade)
  const hotCore = ctx.createRadialGradient(
    b.x - b.r*0.4, b.y - b.r*0.46, 0,
    b.x - b.r*0.4, b.y - b.r*0.46, b.r*0.09
  );
  hotCore.addColorStop(0, 'rgba(255,255,255,0.95)');
  hotCore.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.fillStyle = hotCore;
  ctx.fill();

  // ===== SELO/CÍRCULO DO NÚMERO — estilo 8 Ball Pool: discreto, limpo, etiqueta 3D =====
  if (b.n !== 0 && !opts.skipNumber) {
    const circleR = b.r * 0.5;

    // sombra projetada (separa visualmente o selo da casca da bola, com mais relevo)
    ctx.save();
    ctx.shadowColor = 'rgba(0,0,0,0.65)';
    ctx.shadowBlur = 4;
    ctx.shadowOffsetX = 0.6;
    ctx.shadowOffsetY = 1.2;
    ctx.beginPath();
    ctx.arc(b.x, b.y, circleR, 0, Math.PI*2);
    ctx.fillStyle = '#ffffff';
    ctx.fill();
    ctx.restore();

    // preenchimento com leve gradiente (parece levemente abaulado/3D)
    const sealGrad = ctx.createRadialGradient(
      b.x - circleR*0.3, b.y - circleR*0.35, circleR*0.05,
      b.x, b.y, circleR
    );
    sealGrad.addColorStop(0, '#ffffff');
    sealGrad.addColorStop(0.7, '#f4f4f4');
    sealGrad.addColorStop(1, '#dcdcdc');
    ctx.beginPath();
    ctx.arc(b.x, b.y, circleR, 0, Math.PI*2);
    ctx.fillStyle = sealGrad;
    ctx.fill();

    // aro colorido combinando com a bola — dá um toque de etiqueta "premium"
    if (!isCue) {
      ctx.beginPath();
      ctx.arc(b.x, b.y, circleR*1.06, 0, Math.PI*2);
      ctx.strokeStyle = b.color;
      ctx.lineWidth = Math.max(1, circleR*0.16);
      ctx.stroke();
    }

    // anel de contorno escuro e nítido — garante contraste mesmo nas listradas
    ctx.beginPath();
    ctx.arc(b.x, b.y, circleR*0.96, 0, Math.PI*2);
    ctx.strokeStyle = 'rgba(10,10,10,0.65)';
    ctx.lineWidth = Math.max(1, circleR*0.1);
    ctx.stroke();

    // fino brilho interno na borda superior do anel (acabamento de "etiqueta")
    ctx.beginPath();
    ctx.arc(b.x, b.y, circleR*0.78, Math.PI*0.95, Math.PI*1.85);
    ctx.strokeStyle = 'rgba(255,255,255,0.6)';
    ctx.lineWidth = Math.max(1, circleR*0.12);
    ctx.stroke();

    // sombra interna fina na borda inferior do selo — dá profundidade de "gravado"
    ctx.beginPath();
    ctx.arc(b.x, b.y, circleR*0.9, Math.PI*0.05, Math.PI*0.95);
    ctx.strokeStyle = 'rgba(0,0,0,0.22)';
    ctx.lineWidth = Math.max(1, circleR*0.1);
    ctx.stroke();

    // número — limpo, em negrito, sem contorno pesado, com leve sombra para destacar
    ctx.save();
    ctx.shadowColor = 'rgba(0,0,0,0.2)';
    ctx.shadowBlur = 1.2;
    ctx.fillStyle = '#0a0a0a';
    const fontSize = b.n >= 10 ? circleR*0.96 : circleR*1.1;
    ctx.font = `900 ${fontSize}px "Arial Black",Rajdhani,Arial`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(b.n, b.x, b.y + circleR*0.04);
    ctx.restore();
  }

  // Contorno final da bola + leve realce no topo (define a "casca" da esfera)
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.strokeStyle = 'rgba(0,0,0,0.32)';
  ctx.lineWidth = 1.2;
  ctx.stroke();

  // Contorno mais escuro do lado oposto à luz (reforça o volume esférico)
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r*0.985, Math.PI*0.05, Math.PI*0.65);
  ctx.strokeStyle = 'rgba(0,0,0,0.22)';
  ctx.lineWidth = 1.4;
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r*0.97, Math.PI*1.1, Math.PI*1.75);
  ctx.strokeStyle = 'rgba(255,255,255,0.25)';
  ctx.lineWidth = 1;
  ctx.stroke();
}

// Cada bola (0-19) sempre parece igual, só muda de posição — então em vez de
// redesenhar ~10 gradientes por bola a cada frame (o outro grande motivo da
// gameplay pesada), desenhamos ela UMA vez num canvas pequeno e reaproveitamos
// esse "sprite" com drawImage, que é muito mais barato.
const ballSpriteCache = {};
function getBallSprite(n, r, color) {
  let spr = ballSpriteCache[n];
  if (spr) return spr;
  const pad = 30;
  const size = Math.ceil(r * 2 + pad * 2);
  const c = document.createElement('canvas');
  c.width = Math.round(size * DPR); c.height = Math.round(size * DPR);
  const sctx = c.getContext('2d');
  sctx.setTransform(DPR, 0, 0, DPR, 0, 0);
  const half = size / 2;
  renderBallShape(sctx, { x: half, y: half, r, n, color }, { skipNumber: true });
  spr = { canvas: c, half, size };
  ballSpriteCache[n] = spr;
  return spr;
}
function drawBall(b) {
  const spr = getBallSprite(b.n, b.r, b.color);
  ctx.drawImage(spr.canvas, b.x - spr.half, b.y - spr.half, spr.size, spr.size);
  if (b.n !== 0) drawRollingNumberDecal(ctx, b);
}

// Desenha o selo do número na posição real de rolamento da bola: conforme ela
// gira "rolando sem deslizar" na direção do movimento, o número desliza pra
// frente, encolhe (efeito de curvatura da esfera) até sumir na borda e depois
// reaparece do outro lado — como um número de verdade grudado numa bola girando,
// em vez de ficar sempre fixo e "colado" olhando pra câmera.
function drawRollingNumberDecal(ctx, b) {
  const phase = b.rot || 0;
  const squash = Math.cos(phase);
  if (squash <= 0.05) return; // selo está no hemisfério de baixo/oculto neste instante
  const axisAngle = b.axisAngle || 0;
  const cosA = Math.cos(axisAngle), sinA = Math.sin(axisAngle);
  const along = b.r * Math.sin(phase);
  const cx = b.x + cosA * along;
  const cy = b.y + sinA * along;

  ctx.save();
  ctx.beginPath();
  ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
  ctx.clip(); // nunca deixa o selo vazar pra fora do contorno da bola

  ctx.translate(cx, cy);
  ctx.rotate(axisAngle);
  ctx.scale(Math.max(0.08, squash), 1); // achatamento ao se aproximar da borda
  ctx.rotate(-axisAngle);

  const circleR = b.r * 0.5;
  const fade = 0.55 + 0.45 * squash;

  ctx.save();
  ctx.shadowColor = 'rgba(0,0,0,0.65)';
  ctx.shadowBlur = 4;
  ctx.shadowOffsetX = 0.6;
  ctx.shadowOffsetY = 1.2;
  ctx.globalAlpha = fade;
  ctx.beginPath();
  ctx.arc(0, 0, circleR, 0, Math.PI*2);
  ctx.fillStyle = '#ffffff';
  ctx.fill();
  ctx.restore();

  const sealGrad = ctx.createRadialGradient(-circleR*0.3, -circleR*0.35, circleR*0.05, 0, 0, circleR);
  sealGrad.addColorStop(0, '#ffffff');
  sealGrad.addColorStop(0.7, '#f4f4f4');
  sealGrad.addColorStop(1, '#dcdcdc');
  ctx.globalAlpha = fade;
  ctx.beginPath();
  ctx.arc(0, 0, circleR, 0, Math.PI*2);
  ctx.fillStyle = sealGrad;
  ctx.fill();

  ctx.beginPath();
  ctx.arc(0, 0, circleR*1.06, 0, Math.PI*2);
  ctx.strokeStyle = b.color;
  ctx.lineWidth = Math.max(1, circleR*0.16);
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(0, 0, circleR*0.96, 0, Math.PI*2);
  ctx.strokeStyle = 'rgba(10,10,10,0.65)';
  ctx.lineWidth = Math.max(1, circleR*0.1);
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(0, 0, circleR*0.78, Math.PI*0.95, Math.PI*1.85);
  ctx.strokeStyle = 'rgba(255,255,255,0.6)';
  ctx.lineWidth = Math.max(1, circleR*0.12);
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(0, 0, circleR*0.9, Math.PI*0.05, Math.PI*0.95);
  ctx.strokeStyle = 'rgba(0,0,0,0.22)';
  ctx.lineWidth = Math.max(1, circleR*0.1);
  ctx.stroke();

  ctx.shadowColor = 'rgba(0,0,0,0.2)';
  ctx.shadowBlur = 1.2;
  ctx.fillStyle = '#0a0a0a';
  const fontSize = b.n >= 10 ? circleR*0.96 : circleR*1.1;
  ctx.font = `900 ${fontSize}px "Arial Black",Rajdhani,Arial`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText(b.n, 0, circleR*0.04);

  ctx.restore();
}

function lightenColor(hex, amt) {
  const r = Math.min(255, parseInt(hex.slice(1,3),16)+amt);
  const g = Math.min(255, parseInt(hex.slice(3,5),16)+amt);
  const b2 = Math.min(255, parseInt(hex.slice(5,7),16)+amt);
  return `rgb(${r},${g},${b2})`;
}
function darkenColor(hex, amt) {
  const r = Math.max(0, parseInt(hex.slice(1,3),16)-amt);
  const g = Math.max(0, parseInt(hex.slice(3,5),16)-amt);
  const b2 = Math.max(0, parseInt(hex.slice(5,7),16)-amt);
  return `rgb(${r},${g},${b2})`;
}

// ===== PHYSICS =====
function physicsStep() {
  let anyMoving = false;
  const SUBSTEPS = 4; // divide cada frame em passos menores para evitar tunneling

  for (let step = 0; step < SUBSTEPS; step++) {

  balls.forEach(b => {
    if (!b.active) return;
    if (Math.abs(b.vx) < MIN_SPEED && Math.abs(b.vy) < MIN_SPEED) {
      b.vx = 0; b.vy = 0; return;
    }
    anyMoving = true;
    b.x += b.vx / SUBSTEPS;
    b.y += b.vy / SUBSTEPS;

    // Rotação real de rolamento: o ângulo girado é proporcional à distância
    // percorrida dividida pelo raio (rolar sem deslizar), guardando também o
    // eixo/direção do movimento para desenhar o número "saindo e voltando"
    // de vista como uma bola de verdade girando.
    {
      const stepDist = Math.sqrt((b.vx/SUBSTEPS)**2 + (b.vy/SUBSTEPS)**2);
      if (stepDist > 0.0005) {
        b.rot = (b.rot || 0) + stepDist / b.r;
        if (b.rot > Math.PI*2) b.rot -= Math.PI*2;
        b.axisAngle = Math.atan2(b.vy, b.vx);
      }
    }
    // Fricção aplicada só no último substep
    if (step === SUBSTEPS - 1) {
      b.vx *= FRICTION;
      b.vy *= FRICTION;
    }

    // Pocket detection (PRECISA vir antes da colisão de parede)
    let pocketedNow = false;
    for (let pi = 0; pi < pockets.length; pi++) {
      const p = pockets[pi];
      const pdx = b.x - p.x, pdy = b.y - p.y;
      if (Math.sqrt(pdx*pdx + pdy*pdy) < POCKET_CAPTURE_R) {
        b.active = false;
        b.vx = 0; b.vy = 0;
        playSound('pocket');
        if (b.n !== 0) {
          pocketedThisTurn.push({ n: b.n, pocket: pi });
        } else {
          handleCueBallPocket();
        }
        pocketedNow = true;
        break;
      }
    }
    if (pocketedNow) return;

    // Wall collisions — track rail touch after contact
    if (b.x - b.r < TL) { const spd=Math.abs(b.vx); b.x = TL + b.r; b.vx *= -WALL_RESTITUTION; playSound('wall', spd/14); if (firstContactBall !== null) anyBallTouchedRailAfterContact = true; }
    if (b.x + b.r > TR) { const spd=Math.abs(b.vx); b.x = TR - b.r; b.vx *= -WALL_RESTITUTION; playSound('wall', spd/14); if (firstContactBall !== null) anyBallTouchedRailAfterContact = true; }
    if (b.y - b.r < TT) { const spd=Math.abs(b.vy); b.y = TT + b.r; b.vy *= -WALL_RESTITUTION; playSound('wall', spd/14); if (firstContactBall !== null) anyBallTouchedRailAfterContact = true; }
    if (b.y + b.r > TB) { const spd=Math.abs(b.vy); b.y = TB - b.r; b.vy *= -WALL_RESTITUTION; playSound('wall', spd/14); if (firstContactBall !== null) anyBallTouchedRailAfterContact = true; }
  });

  // Ball-ball collisions
  for (let i=0;i<balls.length;i++) {
    const a = balls[i];
    if (!a.active) continue;
    for (let j=i+1;j<balls.length;j++) {
      const b2 = balls[j];
      if (!b2.active) continue;
      const dx = b2.x - a.x;
      const dy = b2.y - a.y;
      const dist = Math.sqrt(dx*dx+dy*dy);
      if (dist < a.r + b2.r && dist > 0.01) {
        const nx = dx/dist, ny = dy/dist;
        const overlap = (a.r+b2.r-dist)/2;
        a.x -= nx*overlap; a.y -= ny*overlap;
        b2.x += nx*overlap; b2.y += ny*overlap;
        const dvx = b2.vx-a.vx, dvy = b2.vy-a.vy;
        const dot = dvx*nx+dvy*ny;
        if (dot < 0) {
          a.vx += dot*nx; a.vy += dot*ny;
          b2.vx -= dot*nx; b2.vy -= dot*ny;
          {
            const intensity = Math.abs(dot)/16;
            const g = 0.35 + Math.min(1, intensity) * 0.55;
            const played = isBreakShot
              ? playSample('breakHit', { gain: g })
              : playSample('hitBall', { gain: g });
            if (!played) playSound('hit', intensity);
          }
          // Track first contact with cue ball
          if (a.n === 0 && firstContactBall === null) { firstContactBall = b2; }
          if (b2.n === 0 && firstContactBall === null) { firstContactBall = a; }
          // Also mark rail touch for the collided ball (approximation)
          if (firstContactBall !== null && (a.n !== 0 || b2.n !== 0)) anyBallTouchedRailAfterContact = true;
        }
      }
    }
  }

  } // end substep loop
  return anyMoving;
}

function handleCueBallPocket() {
  playSound('foul');
  foulNextTurn = true;
  // cueBall.active is already false from physicsStep
  // onTurnEnd will handle ball-in-hand activation once balls stop
}

function activateBallInHand(restricted) {
  ballInHandMode = true;
  ballInHandRestricted = restricted;
  cueBall.active = false;
  updateHUD(); // corrige HUD travado em "Sua vez" enquanto o overlay de bola na mão está ativo

  // Inicializa o fantasma no local padrão de saída para ficar visível imediatamente
  const cx = (TL + TR) / 2;
  const defaultY = restricted ? TT + (TB - TT) * 0.78 : TT + (TB - TT) * 0.5;
  ballInHandGhostX = cx;
  ballInHandGhostY = defaultY;

  const overlay = document.getElementById('ballInHandOverlay');
  const msg = document.getElementById('ballInHandMsg');
  document.getElementById('ballInHandConfirm').classList.add('visible');
  overlay.classList.add('active');
  if (restricted) {
    msg.innerHTML = '<img src="data:image/svg+xml;base64," alt="Bola 10" style="width:1em;height:1em;vertical-align:-0.15em;border-radius:50%;display:inline-block;"> Arraste a branca para a área de saída e solte para confirmar';
  } else {
    msg.innerHTML = '<img src="data:image/svg+xml;base64," alt="Bola 10" style="width:1em;height:1em;vertical-align:-0.15em;border-radius:50%;display:inline-block;"> Arraste a branca para o local desejado e solte para confirmar';
  }
  setShootEnabled(false);
  // For AI, auto-place intelligently
  if (playerType[currentPlayer] === 'ai') {
    setTimeout(() => {
      const best = aiChooseCueBallPlacement(restricted);
      placeCueBall(best.x, best.y);
    }, 350);
  }
}

function placeCueBall(px, py) {
  // Clamp inside table
  px = Math.max(TL + BALL_R, Math.min(TR - BALL_R, px));
  py = Math.max(TT + BALL_R, Math.min(TB - BALL_R, py));

  // If restricted (break foul), must be in bottom ~25% of table
  if (ballInHandRestricted) {
    const headLine = TT + (TB - TT) * 0.70;
    if (py < headLine) py = headLine + BALL_R;
  }

  // Check no overlap with other balls
  for (const b of balls) {
    if (!b.active || b.n === 0) continue;
    const dx = px - b.x, dy = py - b.y;
    if (Math.sqrt(dx*dx+dy*dy) < BALL_R * 2.2) {
      showToast('⚠️ Posição inválida! Tente outro local.');
      return;
    }
  }

  cueBall.x = px;
  cueBall.y = py;
  cueBall.vx = 0; cueBall.vy = 0;
  cueBall.active = true;
  ballInHandMode = false;
  ballInHandGhostX = null;
  ballInHandGhostY = null;
  document.getElementById('ballInHandOverlay').classList.remove('active');
  document.getElementById('ballInHandConfirm').classList.remove('visible');
  setShootEnabled(true);
  updateHUD();

  if (playerType[currentPlayer] === 'ai') {
    aiThinking = true;
    setShootEnabled(false);
    const hasAim = aiComputeAim();
    if (!hasAim) { aiThinking = false; switchPlayer(); }
    else { scheduleAIAfterMessages(180 + Math.random()*180); }
  }
}

// ===== GAME LOOP =====
function gameLoop() {
  if (!gameRunning) return;
  frameCount++;

  const wasMoving = ballsMoving;
  ballsMoving = physicsStep();

  draw();

  if (wasMoving && !ballsMoving && !ballInHandMode) {
    onTurnEnd();
  }

  animFrame = requestAnimationFrame(gameLoop);
}

function switchPlayer() {
  currentPlayer = 1 - currentPlayer;
  updateHUD();
  setShootEnabled(true);
  power = 50;
  document.getElementById('powerFill').style.width = power + '%';
  document.getElementById('powerVal').textContent = power + '%';
  if (playerType[currentPlayer] === 'ai' && !aiThinking) {
    aiThinking = true;
    setShootEnabled(false);
    const hasAim = aiComputeAim();
    if (!hasAim) { aiThinking = false; currentPlayer = 1 - currentPlayer; updateHUD(); setShootEnabled(true); }
    else { scheduleAIAfterMessages(180 + Math.random()*180); }
  }
}

function onTurnEnd() {
  const pocketedThisShot = pocketedThisTurn.slice();
  const pocketedNums = pocketedThisShot.map(p => p.n);
  pocketedThisTurn = [];

  const cueBallPocketed = !cueBall.active;
  const pocketed10 = pocketedThisShot.find(p => p.n === 10);

  // Taco tacou e a branca não tocou em nenhuma bola nessa jogada inteira
  // (falta por "ar") — som real de "só taca sem acertar".
  if (firstContactBall === null) {
    if (!playSample('whiff', { gain: 0.75 })) playSound('foul', 0.3);
  }

  // ===== REGRA 1: SAÍDA (ESTOURO) =====
  if (isBreakShot) {
    isBreakShot = false;

    if (cueBallPocketed) {
      // Falta na saída: branca encaçapada
      showToast('⚠️ Falta na saída! Bola branca na área de saída');
      // Grupos NÃO definidos mesmo se outras bolas caíram
      // Adversário recebe bola na mão na área de saída
      foulNextTurn = false;
      const nonBreakPocketed = pocketedNums.filter(n => n !== 10);
      // Bolas que caíram ficam fora (não voltam)
      currentPlayer = 1 - currentPlayer;
      updateHUD();
      activateBallInHand(true); // restrito à área de saída
      return;
    }

    const pocketedNonTen = pocketedNums.filter(n => n !== 10);
    const breakHitAny = firstContactBall !== null;

    if (!breakHitAny || pocketedNonTen.length === 0) {
      // Não atingiu o monte ou não encaçapou nada → falta, adversário assume
      showToast('⚠️ Saída inválida! Nenhuma bola encaçapada');
      currentPlayer = 1 - currentPlayer;
      updateHUD();
      activateBallInHand(false);
      return;
    }

    if (pocketed10) {
      // Bola 10 caiu na saída → jogador escolhe: repor ou nova saída
      // Repor outros encaçapados ficam fora
      showBreakModal10();
      return;
    }

    // Saída válida: bolas caídas ficam, não definem grupo ainda
    // Jogador continua (encaçapou bolas)
    resetTurnTracking();
    updateHUD();
    setShootEnabled(true);
    power = 50;
    document.getElementById('powerFill').style.width = power + '%';
    document.getElementById('powerVal').textContent = power + '%';
    if (playerType[currentPlayer] === 'ai' && !aiThinking) {
      aiThinking = true;
      setShootEnabled(false);
      const hasAim = aiComputeAim();
      if (!hasAim) { aiThinking = false; switchPlayer(); }
      else { scheduleAIAfterMessages(180 + Math.random()*180); }
  }
  return;
}

// ===== REGRA 6: DERROTA AUTOMÁTICA COM A BOLA 10 =====
  if (pocketed10) {
    const myGroup = playerGroups[currentPlayer];
    const myBalls = myGroup===0 ? balls.filter(b=>isSolid(b.n)) : balls.filter(b=>isStripe(b.n));
    const allMine = myBalls.every(b=>!b.active);

    if (!allMine) {
      // Encaçapou a 10 antes de limpar o grupo → derrota
      showToast('💀 Bola 10 prematura! Derrota automática');
      setTimeout(() => endGame(1 - currentPlayer), 800);
      return;
    }

    if (cueBallPocketed) {
      // Branca junto com a 10 → derrota
      showToast('💀 Branca junto com a 10! Derrota automática');
      setTimeout(() => endGame(1 - currentPlayer), 800);
      return;
    }
    // Tudo certo → vitória! (a bola 10 vale em qualquer caçapa)
    endGame(currentPlayer);
    return;
  }

  // ===== DETECÇÃO DE FALTA =====
  let foulReason = null;

  if (cueBallPocketed) {
    foulReason = '⚠️ Falta! Bola branca encaçapada';
  } else {
    const myGroup = playerGroups[currentPlayer];
    if (myGroup !== -1 && firstContactBall !== null) {
      // Branca bateu em bola do adversário ou na 10
      const hitMine = (myGroup === 0 && isSolid(firstContactBall.n)) ||
                      (myGroup === 1 && isStripe(firstContactBall.n));
      if (!hitMine) {
        foulReason = '⚠️ Falta! Bola branca bateu em bola errada';
      }
    } else if (myGroup !== -1 && firstContactBall === null) {
      // Branca não tocou nenhuma bola
      foulReason = '⚠️ Falta! Bola branca não tocou nenhuma bola';
    }

    // Nenhuma bola tocou a tabela após contato (só exige se não encaçapou nenhuma)
    if (!foulReason && firstContactBall !== null && !anyBallTouchedRailAfterContact && pocketedNums.length === 0) {
      foulReason = '⚠️ Falta! Nenhuma bola tocou a tabela após o contato';
    }
  }

  if (foulReason) {
    showToast(foulReason);
    resetTurnTracking();
    foulNextTurn = false;
    currentPlayer = 1 - currentPlayer;
    updateHUD();
    activateBallInHand(false);
    return;
  }

  // ===== DEFINIÇÃO DOS GRUPOS =====
  if (playerGroups[0] === -1 && pocketedNums.length > 0) {
    const firstN = pocketedNums.find(n => n !== 10);
    if (firstN !== undefined) {
      if (isSolid(firstN)) {
        playerGroups[currentPlayer] = 0;
        playerGroups[1-currentPlayer] = 1;
        {
          const p0icon = '👤', p0name = getHudPlayerName();
          const p1icon = (playerType[1] === 'ai') ? '🤖' : '👥', p1name = getHudOpponentName(false);
          if (currentPlayer === 0) {
            showGroupReveal(p0name, p0icon, 0, p1name, p1icon, 1);
          } else {
            showGroupReveal(p0name, p0icon, 1, p1name, p1icon, 0);
          }
        }
      } else {
        playerGroups[currentPlayer] = 1;
        playerGroups[1-currentPlayer] = 0;
        {
          const p0icon = '👤', p0name = getHudPlayerName();
          const p1icon = (playerType[1] === 'ai') ? '🤖' : '👥', p1name = getHudOpponentName(false);
          if (currentPlayer === 0) {
            showGroupReveal(p0name, p0icon, 1, p1name, p1icon, 0);
          } else {
            showGroupReveal(p0name, p0icon, 0, p1name, p1icon, 1);
          }
        }
      }
    }
  }

  // ===== VERIFICAR SE PONTUOU =====
  const myGroup = playerGroups[currentPlayer];
  let scoredMine = false;
  if (myGroup === 0) scoredMine = pocketedNums.some(n => isSolid(n));
  else if (myGroup === 1) scoredMine = pocketedNums.some(n => isStripe(n));
  else if (pocketedNums.length > 0) scoredMine = true;

  resetTurnTracking();

  if (!scoredMine) {
    switchPlayer();
  } else {
    updateHUD();
    setShootEnabled(true);
    power = 50;
    document.getElementById('powerFill').style.width = power + '%';
    document.getElementById('powerVal').textContent = power + '%';
    if (playerType[currentPlayer] === 'ai' && !aiThinking) {
      aiThinking = true;
      setShootEnabled(false);
      const hasAim = aiComputeAim();
      if (!hasAim) { aiThinking = false; switchPlayer(); }
      else { scheduleAIAfterMessages(180 + Math.random()*180); }
    }
  }
}

function resetTurnTracking() {
  firstContactBall = null;
  anyBallTouchedRailAfterContact = false;
}

// ===== BREAK MODAL (bola 10 na saída) =====
function showBreakModal10() {
  document.getElementById('breakModal').classList.add('active');
}
function breakChoice(choice) {
  document.getElementById('breakModal').classList.remove('active');
  if (choice === 'replace') {
    // Repor a bola 10 no centro e o jogador continua
    const cx = (TL+TR)/2;
    const cy = TT + (TB-TT)/2;
    const ball10 = { id:10, x:cx, y:cy, vx:0, vy:0, r:BALL_R, color:getBallColor(10), active:true, n:10, rot:0, axisAngle:0 };
    // Remove any inactive 10 and add back
    const idx = balls.findIndex(b => b.n === 10);
    if (idx >= 0) { balls[idx] = ball10; } else { balls.push(ball10); }
    resetTurnTracking();
    updateHUD();
    setShootEnabled(true);
    power = 50;
    document.getElementById('powerFill').style.width = power + '%';
    document.getElementById('powerVal').textContent = power + '%';
    showToast('🎱 Bola 10 reposta! Continue jogando');
    if (playerType[currentPlayer] === 'ai' && !aiThinking) {
      aiThinking = true; setShootEnabled(false);
      const hasAim = aiComputeAim();
      if (!hasAim) { aiThinking = false; switchPlayer(); }
      else { scheduleAIAfterMessages(180 + Math.random()*180); }
    }
  } else {
    // Nova saída: repor tudo e o mesmo jogador sai de novo
    isBreakShot = true;
    resetTurnTracking();
    // Rerack
    initGame();
    updateHUD();
    setShootEnabled(true);
    showToast('🔄 Nova saída!');
  }
}

function endGame(winner) {
  gameRunning = false;
  cancelAnimationFrame(animFrame);
  state.gamesPlayed++;
  consumeChalkGame();

  const isHumanWin = (winner === 0);

  // ===== MODO FICHA =====
  if (currentGameContext === 'ficha') {
    if (isHumanWin) { state.wins++; addCoins(100); checkAchievements({ difficulty: 'hard' }); playSound('win'); }
    else { state.losses++; saveState(); playSound('foul'); }

    const serieDone = handleFichaGameEnd(isHumanWin);
    if (serieDone) {
      // Mostra resultado final da série
      const humanWon = fichaState.humanWins > fichaState.aiWins;
      const bet = fichaState.bet;
      if (humanWon) checkAchievements({ fichaWon: true, fichaBet: bet });
      document.getElementById('modalIcon').textContent = humanWon ? '🎰' : '😤';
      document.getElementById('modalTitle').textContent = humanWon ? 'SÉRIE VENCIDA!' : 'SÉRIE PERDIDA';
      const placar = `${fichaState.humanWins} × ${fichaState.aiWins}`;
      document.getElementById('modalBody').textContent = humanWon
        ? `Você dominou o bar! Placar final: ${placar}`
        : `A IA é boa de mesa! Placar final: ${placar}`;
      const fichaCoins = fichaState.humanWins * 100;
      document.getElementById('modalReward').textContent = humanWon
        ? `+R$ ${fichaCoins} 💵 · +🎟️ ${bet} ficha${bet>1?'s':''} recebidas!`
        : (fichaCoins > 0 ? `+R$ ${fichaCoins} 💵 · -🎟️ ${bet} ficha${bet>1?'s':''} perdidas` : `-🎟️ ${bet} ficha${bet>1?'s':''} perdidas`);
      document.getElementById('modalReward').style.color = humanWon ? '#4caf50' : '#ef5350';
      // Botão "Jogar de Novo" vai para nova aposta
      document.getElementById('resultModal').querySelector('.modal-btn.primary').textContent = 'Apostar de Novo';
      document.getElementById('resultModal').querySelector('.modal-btn.primary').onclick = () => {
        document.getElementById('resultModal').classList.remove('active');
        document.getElementById('resultModal').querySelector('.modal-btn.primary').textContent = 'Jogar de Novo';
        document.getElementById('resultModal').querySelector('.modal-btn.primary').onclick = restartGame;
        showFichaMode();
      };
      document.getElementById('resultModal').classList.add('active');
    } else {
      // Série continua — mostra resultado da partida e botão de continuar
      document.getElementById('modalIcon').textContent = isHumanWin ? '✅' : '❌';
      document.getElementById('modalTitle').textContent = isHumanWin ? 'Partida Vencida!' : 'Partida Perdida';
      document.getElementById('modalBody').textContent = `Placar da série: Você ${fichaState.humanWins} × ${fichaState.aiWins} IA`;
      document.getElementById('modalReward').textContent = isHumanWin
        ? `+R$ 100 💵 · 🎟️ ${fichaState.bet} em jogo — Próxima partida!`
        : `🎟️ ${fichaState.bet} em jogo — Próxima partida!`;
      document.getElementById('modalReward').style.color = isHumanWin ? '#4caf50' : '#ff9800';
      document.getElementById('resultModal').querySelector('.modal-btn.primary').textContent = 'Continuar Série';
      document.getElementById('resultModal').querySelector('.modal-btn.primary').onclick = () => {
        document.getElementById('resultModal').classList.remove('active');
        document.getElementById('resultModal').querySelector('.modal-btn.primary').textContent = 'Jogar de Novo';
        document.getElementById('resultModal').querySelector('.modal-btn.primary').onclick = restartGame;
        // Próxima partida da série
        currentGameContext = 'ficha';
        aiDifficulty = 'hard';
        updateFichaBanner();
        startGame('ai');
      };
      document.getElementById('resultModal').classList.add('active');
    }
    return;
  }

  // ===== MODO CAMPEONATO (mata-mata) =====
  if (currentGameContext === 'champ') {
    const cType = currentChampType;
    const c = champs.find(x => x.id === cType);
    const btnPrimary = document.getElementById('resultModal').querySelector('.modal-btn.primary');

    if (isHumanWin) {
      state.wins++;
      let reward = 100;
      let finished = false;
      let nextRoundName = '';
      if (champBracket && champBracket.type === cType) {
        const m = findPlayerMatch(champBracket.bracket, champBracket.round);
        if (m) m.winner = 'Você';
        champBracket.round++;
        finished = champBracket.round >= champBracket.rounds;
        if (finished) {
          reward = 100 + currentChampReward;
          const champIdx = champs.findIndex(x => x.id === cType);
          if (champIdx >= 0 && champIdx === state.champLevel && state.champLevel < champs.length - 1) {
            state.champLevel++;
          }
          champBracket = null;
          saveChampBracket();
          clearModeSession();
        } else {
          buildNextRound(champBracket.bracket); // monta a próxima fase em tempo real com os vencedores
          nextRoundName = champBracket.roundNames[champBracket.round];
          saveChampBracket();
          saveModeSession('champ', { type: cType, round: champBracket.round });
        }
      }
      addCoins(reward);
      checkAchievements({ champWon: finished ? cType : undefined, difficulty: 'hard' });
      playSound('win');
      currentChampReward = 0;
      currentChampType = null;

      document.getElementById('modalIcon').textContent = finished ? '🏆' : '✅';
      document.getElementById('modalTitle').textContent = finished ? 'CAMPEÃO!' : 'Rodada Vencida!';
      document.getElementById('modalBody').textContent = finished
        ? `Você venceu o ${c ? c.name : 'campeonato'} e é o grande campeão! 🎉`
        : `Você avançou de fase! Próxima rodada: ${nextRoundName}.`;
      document.getElementById('modalReward').textContent = `+R$ ${reward.toLocaleString()} 💵`;
      document.getElementById('modalReward').style.color = '#4caf50';
      btnPrimary.textContent = finished ? 'Ver Campeonatos' : 'Próxima Rodada';
      btnPrimary.onclick = () => {
        document.getElementById('resultModal').classList.remove('active');
        btnPrimary.textContent = 'Jogar de Novo';
        btnPrimary.onclick = restartGame;
        renderChamp();
        showScreen('champScreen');
        if (!finished) openChampBracket(cType);
      };
      document.getElementById('resultModal').classList.add('active');
    } else {
      state.losses++;
      saveState();
      playSound('foul');
      const roundName = (champBracket && champBracket.type === cType) ? champBracket.roundNames[champBracket.round] : '';
      if (champBracket && champBracket.type === cType) {
        const m = findPlayerMatch(champBracket.bracket, champBracket.round);
        if (m) m.winner = (m.p1 === 'Você') ? m.p2 : m.p1;
        champBracket = null;
        saveChampBracket();
      }
      clearModeSession();
      currentChampReward = 0;
      currentChampType = null;

      document.getElementById('modalIcon').textContent = '😢';
      document.getElementById('modalTitle').textContent = 'Eliminado!';
      document.getElementById('modalBody').textContent =
        `Você caiu n${roundName ? 'a ' + roundName : 'o campeonato'} do ${c ? c.name : ''}. O chaveamento será sorteado de novo na próxima tentativa.`;
      document.getElementById('modalReward').textContent = '';
      btnPrimary.textContent = 'Voltar aos Campeonatos';
      btnPrimary.onclick = () => {
        document.getElementById('resultModal').classList.remove('active');
        btnPrimary.textContent = 'Jogar de Novo';
        btnPrimary.onclick = restartGame;
        renderChamp();
        showScreen('champScreen');
      };
      document.getElementById('resultModal').classList.add('active');
    }
    return;
  }

  // ===== MODOS NORMAIS =====
  // Limpar sessão salva pois a partida terminou normalmente
  if (currentGameContext === 'career') {
    clearModeSession();
  }

  if (isHumanWin) {
    state.wins++;
    let reward = 100; // partida rápida
    const ctx = {};

    if (currentCareerIdx >= 0) {
      ctx.cityIdx = currentCareerIdx;
      reward = cities[currentCareerIdx].reward + 100;
      state.careerCity = Math.min(currentCareerIdx+1, cities.length-1);
      currentCareerIdx = -1;
    }
    addCoins(reward);
    checkAchievements({ ...ctx, difficulty: gameMode === 'ai' ? aiDifficulty : null });
    playSound('win');
    showResult(true, reward);
  } else {
    state.losses++;
    saveState();
    playSound('foul');
    showResult(false, 0);
  }
}

function showResult(win, reward) {
  document.getElementById('modalIcon').textContent = win ? '🏆' : '😢';
  document.getElementById('modalTitle').textContent = win ? 'VITÓRIA!' : 'Derrota';
  document.getElementById('modalBody').textContent = win
    ? 'Parabéns! Você venceu a partida de Sinuca 10uilton!'
    : 'Não foi dessa vez. Tente novamente!';
  document.getElementById('modalReward').textContent = win ? `+R$ ${reward.toLocaleString()} 💵` : '';
  document.getElementById('resultModal').classList.add('active');
}

