}
function checkBirthdayBonus() {
  if (!state.profileBirthdate) return;
  const b = new Date(state.profileBirthdate + 'T00:00:00');
  if (isNaN(b.getTime())) return;
  const now = new Date();
  const isBirthdayToday = now.getMonth() === b.getMonth() && now.getDate() === b.getDate();
  if (isBirthdayToday && state.profileBirthdayYear !== now.getFullYear()) {
