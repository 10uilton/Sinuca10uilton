function doShoot(angle, pwr) {
  const chalk = getChalkBonus();
  const boostedPwr = pwr * (1 + chalk.power);
  const speed = Math.min(boostedPwr, 130) * 0.22;
  cueBall.vx = Math.cos(angle) * speed;
  cueBall.vy = Math.sin(angle) * speed;
  ballsMoving = true;
  // Reset per-shot tracking
  firstContactBall = null;
  anyBallTouchedRailAfterContact = false;
  setShootEnabled(false);
  // (Sem som sintetizado aqui — o toque real (bola batendo, bolo de bolas
  // ou "taca sem acertar") já cobre o áudio da jogada. Tocar o clique
  // sintetizado antes ficava estranho, tipo um bipe genérico antes do
  // som de verdade.)
}

// ===== AI INTELIGENTE =====
let aiPlannedPower = 50;

// Verifica se o caminho da branca até um ponto está livre de outras bolas
function aiPathClear(fromX, fromY, toX, toY, excludeN) {
  const dx = toX - fromX, dy = toY - fromY;
  const len = Math.sqrt(dx*dx+dy*dy);
  if (len < 1) return true;
  const ux = dx/len, uy = dy/len;
  for (const b of balls) {
    if (!b.active || b.n === 0 || b.n === excludeN) continue;
    const cx2 = b.x - fromX, cy2 = b.y - fromY;
    const proj = cx2*ux + cy2*uy;
    if (proj < BALL_R || proj > len - BALL_R) continue;
    const perp2 = (cx2*cx2+cy2*cy2) - proj*proj;
    if (perp2 < (BALL_R*2)*(BALL_R*2)) return false;
  }
  return true;
}

// Verifica se o caminho da bola alvo até a caçapa está razoavelmente livre
function aiTargetPathClear(target, pocket) {
  const dx = pocket.x - target.x, dy = pocket.y - target.y;
  const len = Math.sqrt(dx*dx+dy*dy);
  if (len < 1) return true;
  const ux = dx/len, uy = dy/len;
  for (const b of balls) {
    if (!b.active || b.n === 0 || b.n === target.n) continue;
    const cx2 = b.x - target.x, cy2 = b.y - target.y;
    const proj = cx2*ux + cy2*uy;
    if (proj < BALL_R || proj > len + BALL_R) continue;
    const perp2 = (cx2*cx2+cy2*cy2) - proj*proj;
    if (perp2 < (BALL_R*1.9)*(BALL_R*1.9)) return false;
  }
  return true;
}

// Estima onde a branca ficará após bater na bola alvo (trajetória tangente)
function aiCueBallAfter(cueX, cueY, target, angle) {
  const nx = (target.x - cueX), ny = (target.y - cueY);
  const nlen = Math.sqrt(nx*nx+ny*ny) || 1;
  // componente tangente da direção da branca
  const dx = Math.cos(angle), dy = Math.sin(angle);
  const dot = dx*(nx/nlen) + dy*(ny/nlen);
  const tx = dx - dot*(nx/nlen), ty = dy - dot*(ny/nlen);
  const tlen = Math.sqrt(tx*tx+ty*ty) || 1;
  return { x: target.x + (tx/tlen)*BALL_R*5, y: target.y + (ty/tlen)*BALL_R*5 };
}

// Pontuação de posicionamento da branca após a tacada (evitar caçapas, preferir centro)
function aiPositionScore(x, y) {
  let score = 0;
  // Penalizar perto das caçapas
  for (const p of pockets) {
    const d = Math.hypot(x - p.x, y - p.y);
    if (d < BALL_R * 5) score -= (BALL_R * 5 - d) * 3;
  }
  // Preferir área central da mesa
  const cx = (TL+TR)/2, cy = (TT+TB)/2;
  const distCenter = Math.hypot(x - cx, y - cy);
  score -= distCenter * 0.3;
  return score;
}

function aiComputeAim() {
  const myGroup = playerGroups[currentPlayer];
  let targets;
  if (myGroup === 0) targets = balls.filter(b => isSolid(b.n) && b.active);
  else if (myGroup === 1) targets = balls.filter(b => isStripe(b.n) && b.active);
  else targets = balls.filter(b => b.n !== 0 && b.n !== 10 && b.active);

  // Sem bolas do meu grupo → atirar na 10
  if (targets.length === 0) {
    const b10 = balls.find(b => b.n === 10 && b.active);
    if (b10) targets = [b10];
  }

  if (!targets.length || !cueBall.active) return false;

  const chalkBonus = getChalkBonus();
  const diff = aiDifficulty; // 'easy' | 'medium' | 'hard'

  // ===== FÁCIL: escolhe bola mais perto e atira sem pensar muito =====
  if (diff === 'easy') {
    // Encontra a bola mais próxima e atira direto nela
    let bestTarget = null, bestDist = Infinity;
    for (const t of targets) {
      const d = Math.hypot(t.x - cueBall.x, t.y - cueBall.y);
      if (d < bestDist) { bestDist = d; bestTarget = t; }
    }
    if (!bestTarget) return false;
    const angle = Math.atan2(bestTarget.y - cueBall.y, bestTarget.x - cueBall.x);
    // Muito erro — IA fácil erra bastante
    const err = (Math.random() - 0.5) * 0.32;
    aiPlannedPower = 30 + Math.random() * 40;
    cueAngle = angle + err;
    power = Math.round(aiPlannedPower);
    document.getElementById('powerFill').style.width = power + '%';
    document.getElementById('powerVal').textContent = power + '%';
    const deg = Math.round(cueAngle * 180 / Math.PI);
    document.querySelectorAll('#angleInfo').forEach(el => el.textContent = deg + '°');
    return true;
  }

  // ===== ANÁLISE DE TODOS OS TIROS POSSÍVEIS (médio e difícil) =====
  let bestAngle = null, bestPower = 55, bestScore = -Infinity, bestStraightness = 1, bestCueDist = 0;

  for (const target of targets) {
    for (const pocket of pockets) {
      const dtpx = pocket.x - target.x;
      const dtpy = pocket.y - target.y;
      const dtpLen = Math.hypot(dtpx, dtpy);
      if (dtpLen < 1) continue;

      const hitX = target.x - (dtpx/dtpLen) * BALL_R * 2;
      const hitY = target.y - (dtpy/dtpLen) * BALL_R * 2;
      const angle = Math.atan2(hitY - cueBall.y, hitX - cueBall.x);
      const cueDist = Math.hypot(hitX - cueBall.x, hitY - cueBall.y);

      if (!aiPathClear(cueBall.x, cueBall.y, hitX, hitY, target.n)) continue;
      if (!aiTargetPathClear(target, pocket)) continue;

      const cueDir = Math.atan2(target.y - cueBall.y, target.x - cueBall.x);
      const targetDir = Math.atan2(dtpy, dtpx);
      let angleDiff = Math.abs(cueDir - targetDir);
      while (angleDiff > Math.PI) angleDiff = Math.abs(angleDiff - Math.PI * 2);
      const straightness = Math.cos(angleDiff);

      // Cortes muito finos (quase 90°) são fisicamente difíceis mesmo para um
      // jogador de verdade — penaliza mais forte para a IA não "achar fácil"
      // um corte que na prática tem baixa taxa de acerto.
      if (straightness < 0.12) continue; // corte impossível/ínfimo, nem considera

      let score = 0;
      score -= dtpLen * 1.8;
      score -= cueDist * 0.5;
      score += straightness * 70;
      // penalidade extra progressiva para cortes finos
      score -= (1 - straightness) * (1 - straightness) * 90;

      if (dtpLen < BALL_R * 6) score += 100;
      if (dtpLen < BALL_R * 3) score += 140;

      // Médio e difícil consideram posicionamento (difícil com peso maior)
      if (diff === 'hard' || diff === 'medium') {
        const posWeight = diff === 'hard' ? 1.3 : 0.55;
        const afterPos = aiCueBallAfter(cueBall.x, cueBall.y, target, angle);
        score += aiPositionScore(afterPos.x, afterPos.y) * posWeight;

        // Evitar deixar a branca perto de outra caçapa após o impacto (scratch)
        let cueEndX = cueBall.x + Math.cos(angle) * (cueDist + BALL_R * 8);
        let cueEndY = cueBall.y + Math.sin(angle) * (cueDist + BALL_R * 8);
        for (const p of pockets) {
          const scratchD = Math.hypot(cueEndX - p.x, cueEndY - p.y);
          if (scratchD < BALL_R * 3.5) score -= (diff === 'hard' ? 260 : 160);
        }

        // Difícil pensa um passo à frente: prefere deixar a bola alvo seguinte
        // acessível (ataque), não só evitar erro (defesa)
        if (diff === 'hard') {
          let nextBestForOpp = -Infinity;
          for (const t2 of targets) {
            if (t2.n === target.n) continue;
            for (const p2 of pockets) {
              const dd = Math.hypot(p2.x - t2.x, p2.y - t2.y);
              const cd2 = Math.hypot(t2.x - afterPos.x, t2.y - afterPos.y);
              const val = 200 - dd * 1.2 - cd2 * 0.4;
              if (val > nextBestForOpp) nextBestForOpp = val;
            }
          }
          if (nextBestForOpp > -Infinity) score += nextBestForOpp * 0.18;
        }
      }

      score += chalkBonus.precision * 30;

      if (score > bestScore) {
        bestScore = score;
        bestAngle = angle;
        bestStraightness = straightness;
        bestCueDist = cueDist;
        const distNorm = Math.min(dtpLen / (TR - TL), 1);
        // Difícil: quase nenhuma aleatoriedade de força; médio: um pouco mais
        const randFactor = diff === 'hard' ? 3 : 10;
        bestPower = 38 + distNorm * 48 + Math.random() * randFactor;
      }
    }
  }

  // Nenhuma tacada de ataque boa o bastante encontrada — joga na defesa
  // (mais realista que simplesmente arriscar uma tacada ruim)
  const potThreshold = diff === 'hard' ? 15 : (diff === 'medium' ? -20 : -Infinity);
  if (bestAngle === null || bestScore < potThreshold) {
    if (diff === 'hard' || diff === 'medium') {
      const played = aiPlaySafety(targets, diff);
      if (played) return true;
    }
  }

  // Fallback: bater na bola mais próxima
  if (bestAngle === null) {
    let fallbackScore = -Infinity;
    for (const target of targets) {
      const angle = Math.atan2(target.y - cueBall.y, target.x - cueBall.x);
      const d = Math.hypot(target.x - cueBall.x, target.y - cueBall.y);
      const score = -d;
      if (score > fallbackScore) {
        fallbackScore = score;
        bestAngle = angle;
        bestPower = 35 + Math.random() * 15;
      }
    }
  }

  if (bestAngle === null) return false;

  // Erro proporcional à dificuldade e ao quão fino é o corte
  // Difícil: erro mínimo, quase um jogador profissional; Médio: erro moderado
  const cutSeverity = 1 - Math.max(0, Math.min(1, bestStraightness)); // 0 (reto) a 1 (rasante)
  const baseError = diff === 'hard' ? 0.010 : 0.055;
  const cutPenalty = diff === 'hard' ? cutSeverity * 0.018 : cutSeverity * 0.05;
  const errorScale = 1 - chalkBonus.precision * 0.5;
  const err = (Math.random() - 0.5) * 2 * (baseError + cutPenalty) * errorScale;

  aiPlannedPower = Math.max(20, Math.min(95, bestPower));
  cueAngle = bestAngle + err;
  power = Math.round(aiPlannedPower);
  document.getElementById('powerFill').style.width = power + '%';
  document.getElementById('powerVal').textContent = power + '%';
  const deg = Math.round(cueAngle * 180 / Math.PI);
  document.querySelectorAll('#angleInfo').forEach(el => el.textContent = deg + '°');
  return true;
}

// IA joga na defesa: quando não há tacada de ataque confiável, escolhe um
// toque legal que deixe a bola branca em posição ruim para o adversário
// (longe de caçapas, sem deixar bolas "de bandeja").
function aiPlaySafety(targets, diff) {
  if (!targets.length || !cueBall.active) return false;
  let bestAngle = null, bestScore = -Infinity;

  for (const target of targets) {
    const baseAngle = Math.atan2(target.y - cueBall.y, target.x - cueBall.x);
    const range = diff === 'hard' ? 0.55 : 0.35;
    const steps = diff === 'hard' ? 14 : 8;
    for (let i = 0; i <= steps; i++) {
      const offset = -range + (2 * range) * (i / steps);
      const angle = baseAngle + offset;
      const dirX = Math.cos(angle), dirY = Math.sin(angle);
      const contactX = target.x - dirX * BALL_R * 2;
      const contactY = target.y - dirY * BALL_R * 2;
      if (!aiPathClear(cueBall.x, cueBall.y, contactX, contactY, target.n)) continue;

      const afterPos = aiCueBallAfter(cueBall.x, cueBall.y, target, angle);
      let score = aiPositionScore(afterPos.x, afterPos.y) * 1.6;

      // Evitar deixar a bola alvo perto de uma caçapa (não "servir" o adversário)
      for (const p of pockets) {
        const dTgt = Math.hypot(target.x - p.x, target.y - p.y);
        if (dTgt < BALL_R * 5) score -= (BALL_R * 5 - dTgt) * 1.5;
      }

      // Preferir deixar a branca longe de todas as bolas do adversário
      for (const b of balls) {
        if (!b.active || b.n === 0 || b.n === target.n) continue;
        const d = Math.hypot(afterPos.x - b.x, afterPos.y - b.y);
        if (d < BALL_R * 4) score -= (BALL_R * 4 - d) * 1.2;
      }

      // Nunca fazer scratch numa defesa
      let scratched = false;
      for (const p of pockets) {
        if (Math.hypot(afterPos.x - p.x, afterPos.y - p.y) < BALL_R * 3.2) { scratched = true; break; }
      }
      if (scratched) score -= 500;

      if (score > bestScore) { bestScore = score; bestAngle = angle; }
    }
  }

  if (bestAngle === null) return false;

  const err = (Math.random() - 0.5) * (diff === 'hard' ? 0.02 : 0.05);
  aiPlannedPower = (diff === 'hard' ? 16 : 20) + Math.random() * 12;
  cueAngle = bestAngle + err;
  power = Math.round(aiPlannedPower);
  document.getElementById('powerFill').style.width = power + '%';
  document.getElementById('powerVal').textContent = power + '%';
  const deg = Math.round(cueAngle * 180 / Math.PI);
  document.querySelectorAll('#angleInfo').forEach(el => el.textContent = deg + '°');
  return true;
}

// IA escolhe o melhor lugar para posicionar a branca (ball-in-hand inteligente)
function aiChooseCueBallPlacement(restricted) {
  const cx = (TL + TR) / 2;
  const myGroup = playerGroups[currentPlayer];
  let targets;
  if (myGroup === 0) targets = balls.filter(b => isSolid(b.n) && b.active);
  else if (myGroup === 1) targets = balls.filter(b => isStripe(b.n) && b.active);
  else targets = balls.filter(b => b.n !== 0 && b.n !== 10 && b.active);
  if (targets.length === 0) {
    const b10 = balls.find(b => b.n === 10 && b.active);
    if (b10) targets = [b10];
  }

  const yMin = restricted ? TT + (TB - TT) * 0.72 : TT + BALL_R * 2;
  const yMax = TB - BALL_R * 2;

  let bestX = cx, bestY = restricted ? TT + (TB - TT) * 0.78 : (TT + TB) / 2;
  let bestScore = -Infinity;

  // Testar uma grade de posições candidatas (difícil: grade mais densa)
  const steps = aiDifficulty === 'hard' ? 14 : aiDifficulty === 'medium' ? 8 : 4;
  for (let xi = 0; xi <= steps; xi++) {
    for (let yi = 0; yi <= steps; yi++) {
      const tx = TL + BALL_R * 2 + (TR - TL - BALL_R * 4) * (xi / steps);
      const ty = yMin + (yMax - yMin) * (yi / steps);

      // Verificar sobreposição com outras bolas
      let overlap = false;
      for (const b of balls) {
        if (!b.active || b.n === 0) continue;
        if (Math.hypot(tx - b.x, ty - b.y) < BALL_R * 2.5) { overlap = true; break; }
      }
      if (overlap) continue;

      // Pontuar: para cada bola alvo, qual é o melhor tiro daqui?
      let posScore = aiPositionScore(tx, ty);
      for (const target of targets) {
        for (const pocket of pockets) {
          const dtpx = pocket.x - target.x, dtpy = pocket.y - target.y;
          const dtpLen = Math.hypot(dtpx, dtpy);
          if (dtpLen < 1) continue;
          const hitX = target.x - (dtpx / dtpLen) * BALL_R * 2;
          const hitY = target.y - (dtpy / dtpLen) * BALL_R * 2;
          if (!aiPathClear(tx, ty, hitX, hitY, target.n)) continue;
          if (!aiTargetPathClear(target, pocket)) continue;
          const cueDist = Math.hypot(hitX - tx, hitY - ty);
          posScore += 80 - cueDist * 0.3 - dtpLen * 0.5;
        }
      }
      if (posScore > bestScore) {
        bestScore = posScore;
        bestX = tx; bestY = ty;
      }
    }
  }
  return { x: bestX, y: bestY };
}

function aiShoot() {
  aiThinking = false;
  if (!gameRunning || !cueBall.active) return;

  doShoot(cueAngle, aiPlannedPower);
}

// ===== PAUSE =====
function pauseGame() {
  if (!gameRunning) return;
  gameRunning = false;
  cancelAnimationFrame(animFrame);
  document.getElementById('pauseModal').classList.add('active');
}
function resumeGame() {
  document.getElementById('pauseModal').classList.remove('active');
  gameRunning = true;
  gameLoop();
}

// ===== KEYBOARD (desktop) =====
document.addEventListener('keydown', e => {
  if (!gameRunning) return;
  if (e.key === 'ArrowLeft') cueAngle -= 0.05;
  if (e.key === 'ArrowRight') cueAngle += 0.05;
  if (e.key === 'ArrowUp') { power = Math.min(100, power+5); document.getElementById('powerFill').style.width=power+'%'; document.getElementById('powerVal').textContent=power+'%'; }
  if (e.key === 'ArrowDown') { power = Math.max(5, power-5); document.getElementById('powerFill').style.width=power+'%'; document.getElementById('powerVal').textContent=power+'%'; }
  if (e.key === ' ') shoot();
  if (e.key === 'Escape') pauseGame();
  const deg = Math.round(cueAngle * 180 / Math.PI);
  document.getElementById('angleInfo').textContent = deg + '°';
});

