function useChalk(id) {
  const stockKey = id === 'giz_branco' ? 'chalkWhite' : 'chalkBlack';
  const gamesKey = id === 'giz_branco' ? 'chalkWhiteGames' : 'chalkBlackGames';
  if (state[stockKey] <= 0) { showToast('Sem estoque de giz!'); return; }
  state[stockKey] -= 1;
  state[gamesKey] = 3;
  state.activeChalk = id;
  saveState();
  renderShop();
  const nome = id === 'giz_branco' ? 'Giz Branco' : 'Giz Preto';
  showToast(`${nome} ativado! Dura 3 partidas. ✓`);
  playSound('win');
}

function consumeChalkGame() {
  if (state.activeChalk === 'none') return;
  const gamesKey = state.activeChalk === 'giz_branco' ? 'chalkWhiteGames' : 'chalkBlackGames';
  if (state[gamesKey] > 0) {
    state[gamesKey]--;
    if (state[gamesKey] === 0) {
      state.activeChalk = 'none';
      saveState();
      showToast('O efeito do giz acabou!');
    } else {
      saveState();
    }
  }
}

function getChalkBonus() {
  if (state.activeChalk === 'giz_branco' && state.chalkWhiteGames > 0) {
    return { precision: 0.20, power: 0 };
  }
  if (state.activeChalk === 'giz_preto' && state.chalkBlackGames > 0) {
    return { precision: 0.30, power: 0.30 };
  }
  return { precision: 0, power: 0 };
}

