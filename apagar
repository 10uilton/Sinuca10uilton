  const wrap = document.querySelector('.table-wrap');
  const wr = wrap.getBoundingClientRect();
  W = wr.width;
  H = wr.height;
  DPR = Math.min(window.devicePixelRatio || 1, 3);
  canvas.width = Math.round(W * DPR);
  canvas.height = Math.round(H * DPR);
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
  // Mudou a densidade de pixel: sprites das bolas cacheados na resolução antiga ficariam borrados
  for (const k in ballSpriteCache) delete ballSpriteCache[k];
  bgCacheSignature = null;

  // Registrar eventos de mira/toque no canvas (só faz uma vez)
  addCanvasListeners();

  const margin = 24;
  const pocketR = 17;
  TL = margin + pocketR * 0.7;
  TR = W - margin - pocketR * 0.7;
  TT = margin + pocketR * 0.7;
  TB = H - margin - pocketR * 0.7;

  const tableW = TR - TL;
  const tableH = TB - TT;

  pockets = [
    { x: TL,      y: TT },                  // canto superior-esquerdo
    { x: TR,      y: TT },                  // canto superior-direito
    { x: TL - 4,  y: TT + tableH/2 },       // meio lado esquerdo
    { x: TR + 4,  y: TT + tableH/2 },       // meio lado direito
    { x: TL,      y: TB },                  // canto inferior-esquerdo
    { x: TR,      y: TB },                  // canto inferior-direito
  ];
}

