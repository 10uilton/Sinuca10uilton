  if (profileName) used.add(profileName);
  return used;
}
function randomBrazilianName(usedSet) {
  let name, tries = 0;
  do {
    if (Math.random() < 0.12) {
      name = BRAZIL_SPECIAL_NAMES[Math.floor(Math.random() * BRAZIL_SPECIAL_NAMES.length)];
    } else {
      const f = BRAZIL_FIRST_NAMES[Math.floor(Math.random() * BRAZIL_FIRST_NAMES.length)];
      const l = BRAZIL_LAST_NAMES[Math.floor(Math.random() * BRAZIL_LAST_NAMES.length)];
      name = `${f} ${l}`;
    }
    tries++;
  } while (usedSet.has(name) && tries < 60);
  usedSet.add(name);
  return name;
}

