  state.profileFirstName = document.getElementById('profileFirstName').value.trim();
  state.profileLastName = document.getElementById('profileLastName').value.trim();
  state.profileGender = document.getElementById('profileGender').value;
  state.profileBirthdate = document.getElementById('profileBirthdate').value;
  saveState();
  renderProfileWidget();
  checkBirthdayBonus();
  showToast('✅ Perfil salvo!');
  goMenu();
}
function renderProfileWidget() {
  const wrap = document.getElementById('profileWidget');
  if (!wrap) return;
  const hasProfile = !!(state.profileFirstName || state.profileBirthdate);
  const avatar = state.profilePhoto
    ? `<div class="profile-avatar-wrap"><img class="profile-avatar" src="${state.profilePhoto}" alt="Foto do perfil"></div>`
    : `<div class="profile-avatar-wrap"><div class="profile-avatar-empty">👤</div></div>`;
  if (!hasProfile) {
    wrap.innerHTML = `${avatar}<div class="profile-widget-cta">+ Criar Perfil</div>`;
    return;
  }
  const age = calcAge(state.profileBirthdate);
  const fullName = [state.profileFirstName, state.profileLastName].filter(Boolean).join(' ') || 'Jogador';
  wrap.innerHTML = `${avatar}
    <div class="profile-widget-name">${fullName}</div>
    ${age !== null ? `<div class="profile-widget-age">${age} anos</div>` : ''}`;
}
function getProfilePlayerName() {
